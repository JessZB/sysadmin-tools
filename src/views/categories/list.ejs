<%- include('../layout/header') %>

<div class="dashboard-header d-flex justify-content-between align-items-center mb-5 sticky-top" style="z-index: 1000; margin-top: -20px;">
    <div>
        <h2 class="text-white mb-0 font-display fw-bold">
            <i class="bi bi-diagram-3 me-2 text-primary"></i>Categorías y Módulos
        </h2>
        <p class="text-white-50 small mb-0 mt-1">Configuración del Registro de Auto-descubrimiento</p>
    </div>
    <button class="btn btn-action-premium btn-ping-premium px-4" id="btnNewCategory" data-action="document.getElementById('formCategory').reset(); $('#categoryId').val(''); $('#modalCategory').modal('show');">
        <i class="bi bi-plus-lg me-2"></i>Nueva Categoría
    </button>
</div>

<div class="row g-4">
    <!-- Panel Izquierdo: Lista de Categorías CRUD -->
    <div class="col-lg-5">
        <div class="card glass-effect border-opacity-10 rounded-4 overflow-hidden shadow-lg h-100">
            <div class="card-header border-bottom border-white border-opacity-10 bg-transparent p-4">
                <h5 class="text-white font-tech mb-0"><i class="bi bi-tags-fill me-2 text-primary"></i>Categorías Sistema</h5>
            </div>
            <div class="card-body p-0">
                <div class="list-group list-group-flush bg-transparent">
                    <% categories.forEach(function(cat) { %>
                        <div class="list-group-item bg-transparent border-white border-opacity-10 text-white p-4 d-flex justify-content-between align-items-center transition-base hover-glass">
                            <div class="d-flex align-items-center">
                                <div class="bg-dark text-primary rounded p-2 d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">
                                    <i class="bi <%= cat.icon %> fs-5"></i>
                                </div>
                                <div class="ms-3">
                                    <h6 class="mb-0 font-tech text-uppercase ls-1"><%= cat.name %></h6>
                                    <small class="text-white-50"><%= cat.description || 'Sin descripción' %></small>
                                </div>
                            </div>
                            <% if(cat.id !== 1) { %>
                                <div class="dropdown">
                                    <button class="btn btn-sm btn-icon text-white-50" data-bs-toggle="dropdown"><i class="bi bi-three-dots-vertical"></i></button>
                                    <ul class="dropdown-menu dropdown-menu-dark glass-effect border-opacity-10">
                                        <li><a class="dropdown-item cursor-pointer" data-id="<%= cat.id %>" data-name="<%= cat.name %>" data-desc="<%= cat.description %>" data-icon="<%= cat.icon %>" data-action="editCategory(this)"><i class="bi bi-pencil me-2 text-info"></i>Editar</a></li>
                                        <li><hr class="dropdown-divider opacity-25"></li>
                                        <li><a class="dropdown-item text-danger cursor-pointer" data-id="<%= cat.id %>" data-action="deleteCategory(<%= cat.id %>)"><i class="bi bi-trash me-2"></i>Eliminar</a></li>
                                    </ul>
                                </div>
                            <% } else { %>
                                <span class="badge text-bg-secondary font-tech border border-white border-opacity-25">PREDETERMINADO</span>
                            <% } %>
                        </div>
                    <% }); %>
                </div>
            </div>
        </div>
    </div>

    <!-- Panel Derecho: Mapeo de Módulos (Auto-descubiertos) -->
    <div class="col-lg-7">
        <div class="card glass-effect border-opacity-10 rounded-4 overflow-hidden shadow-lg h-100">
            <div class="card-header border-bottom border-white border-opacity-10 bg-transparent p-4 d-flex justify-content-between align-items-center">
                <h5 class="text-white font-tech mb-0"><i class="bi bi-motherboard-fill me-2 text-primary"></i>Registro de Módulos</h5>
                <span class="badge text-bg-info font-tech border border-info border-opacity-25 bg-opacity-10"><i class="bi bi-robot me-1"></i>AUTO-DISCOVERY ACTIVO</span>
            </div>
            <div class="card-body p-4 bg-transparent bg-opacity-10" style="max-height: 70vh; overflow-y: auto;">
                <% groupedModules.forEach(function(catBox) { %>
                    <div class="mb-5">
                        <h6 class="text-lavender font-tech text-uppercase mb-3 pb-2 border-bottom border-light border-opacity-10">
                            <i class="bi <%= catBox.icon %> me-2"></i><%= catBox.name %>
                        </h6>
                        <div class="row g-3">
                            <% catBox.modules.forEach(function(mod) { %>
                                <div class="col-md-6">
                                    <div class="card glass-effect border-opacity-10 <%= mod.is_configured ? 'border-primary border-opacity-25' : 'border-danger error-blink' %> p-3 h-100">
                                        <div class="d-flex justify-content-between align-items-start mb-2">
                                            <div class="d-flex align-items-center">
                                                <i class="bi <%= mod.icon || 'bi-box' %> fs-4 <%= mod.is_configured ? 'text-primary' : 'text-danger' %> me-3"></i>
                                                <div>
                                                    <h6 class="text-white font-tech text-uppercase ls-1 mb-0"><%= mod.name %></h6>
                                                    <small class="text-white-50 font-monospace">/<%= mod.code %></small>
                                                </div>
                                            </div>
                                            <% if(!mod.is_configured) { %>
                                                <i class="bi bi-exclamation-triangle-fill text-danger" title="Falta .routes.ts o .ejs"></i>
                                            <% } %>
                                        </div>
                                        <div class="mt-3">
                                            <select class="form-select form-select-sm glass-effect border-opacity-10 text-white font-tech ls-1 module-category-select" data-module-code="<%= mod.code %>">
                                                <% categories.forEach(function(c) { %>
                                                    <option value="<%= c.id %>" <%= mod.category_id == c.id ? 'selected' : '' %> class="bg-dark"><%= c.name %></option>
                                                <% }); %>
                                            </select>
                                        </div>
                                    </div>
                                </div>
                            <% }); %>
                        </div>
                    </div>
                <% }); %>
            </div>
        </div>
    </div>
</div>

<!-- Modal Form Categoría -->
<div class="modal fade" id="modalCategory" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content glass-effect border-opacity-10 border-white">
            <div class="modal-header glass-effect border-bottom-0 p-4">
                <h5 class="modal-title font-display fw-bold text-white"><i class="bi bi-tag-fill me-2 text-primary"></i>Propiedades Categoría</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4">
                <form id="formCategory">
                    <input type="hidden" id="categoryId">
                    <div class="mb-4">
                        <label class="form-label text-white-50 small fw-bold text-uppercase ls-1">Nombre</label>
                        <input type="text" class="form-control glass-effect border-opacity-10 text-white p-3 font-tech" id="catName" required>
                    </div>
                    <div class="mb-4">
                        <label class="form-label text-white-50 small fw-bold text-uppercase ls-1">Descripción</label>
                        <input type="text" class="form-control glass-effect border-opacity-10 text-white p-3" id="catDesc">
                    </div>
                    <div class="mb-4">
                        <label class="form-label text-white-50 small fw-bold text-uppercase ls-1">Icono (Bootstrap Icons ex: bi-folder)</label>
                        <input type="text" class="form-control glass-effect border-opacity-10 text-white p-3 font-monospace" id="catIcon" value="bi-folder">
                    </div>
                </form>
            </div>
            <div class="modal-footer border-top-0 p-4">
                <button type="button" class="btn btn-frosted border border-opacity-10 text-white px-4" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" class="btn btn-action-premium btn-ping-premium px-5" id="btnSaveCategory" data-action="saveCategory()">Guardar</button>
            </div>
        </div>
    </div>
</div>

<style>
    .hover-glass:hover { background: rgba(255,255,255,0.05) !important; }
    .error-blink { animation: pulse-border 2s infinite; }
    @keyframes pulse-border {
        0% { border-color: rgba(220, 53, 69, 0.4); }
        50% { border-color: rgba(220, 53, 69, 1); }
        100% { border-color: rgba(220, 53, 69, 0.4); }
    }
</style>


<%- include('../layout/footer') %>
