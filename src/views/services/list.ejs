<%- include('../layout/header') %>

    <style>
        .services-container {
            padding: 20px;
            position: relative;
        }

        /* Dashboard Header */
        .services-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 2rem;
            background: var(--glass-bg);
            backdrop-filter: blur(12px);
            border: 1px solid var(--glass-border);
            border-radius: 24px;
            padding: 1.5rem;
            box-shadow: var(--glass-shadow);
        }

        .title-section h2 {
            font-size: 1.75rem;
            font-weight: 700;
            color: #fff;
            margin: 0;
            font-family: var(--font-tech);
        }

        .title-section p {
            color: rgba(255, 255, 255, 0.6);
            font-size: 0.95rem;
            margin: 0;
        }

        .header-actions {
            display: flex;
            gap: 10px;
        }

        .btn-action {
            padding: 0.6rem 1.2rem;
            border-radius: 12px;
            font-weight: 600;
            font-size: 0.9rem;
            border: none;
            cursor: pointer;
            transition: var(--transition);
            display: inline-flex;
            align-items: center;
            gap: 6px;
            font-family: var(--font-tech);
        }

        .btn-primary-custom {
            background: var(--gradient-neon);
            color: white;
            box-shadow: var(--shadow-neon);
        }

        .btn-primary-custom:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(0, 210, 255, 0.4);
        }

        .btn-success-custom {
            background: var(--gradient-success);
            color: white;
            box-shadow: 0 4px 10px rgba(0, 255, 204, 0.3);
        }

        .btn-success-custom:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(0, 255, 204, 0.4);
        }

        .btn-info-custom {
            background: var(--gradient-info);
            color: white;
            box-shadow: 0 4px 10px rgba(13, 202, 240, 0.3);
        }

        .btn-info-custom:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(13, 202, 240, 0.4);
        }

        .btn-danger {
            background: var(--gradient-danger);
            color: white;
            box-shadow: 0 4px 10px rgba(255, 77, 109, 0.3);
        }

        .btn-danger:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(255, 77, 109, 0.4);
        }

        /* Stats Container Glass */
        .stats-container {
            background: var(--glass-bg);
            backdrop-filter: blur(12px);
            border: 1px solid var(--glass-border);
            border-radius: 24px;
            padding: 30px;
            margin-bottom: 40px;
            box-shadow: var(--glass-shadow);
            display: flex;
            justify-content: space-around;
            align-items: center;
        }

        .stat-item {
            text-align: center;
        }

        .stat-value {
            font-family: var(--font-tech);
            font-size: 2.5rem;
            font-weight: 700;
            color: #fff;
            line-height: 1;
        }

        .stat-label {
            font-size: 0.9rem;
            color: rgba(255, 255, 255, 0.5);
            text-transform: uppercase;
            letter-spacing: 0.1em;
            margin-top: 5px;
        }

        /* Service Cards Premium */
        .service-card {
            background: var(--glass-bg);
            border: 1px solid var(--glass-border);
            border-radius: 24px;
            padding: 25px;
            transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
            position: relative;
            overflow: hidden;
            box-shadow: var(--glass-shadow);
            height: 100%;
            margin-bottom: 24px;
            display: flex;
            flex-direction: column;
        }

        .service-card:hover {
            transform: translateY(-8px);
            border-color: var(--neon-blue);
            box-shadow: 0 20px 40px rgba(0, 210, 255, 0.1);
        }

        .card-status-line {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 4px;
            z-index: 2;
        }

        .line-online { background: var(--success-mint); box-shadow: 0 0 10px var(--success-mint); }
        .line-offline { background: var(--punch-red); box-shadow: 0 0 10px var(--punch-red); }

        .service-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: 15px;
        }

        .service-name {
            font-family: var(--font-tech);
            font-size: 1.25rem;
            color: #fff;
            font-weight: 600;
            margin-bottom: 5px;
        }

        .service-url {
            font-size: 0.8rem;
            color: rgba(255, 255, 255, 0.4);
            font-family: monospace;
            background: rgba(0, 0, 0, 0.2);
            padding: 2px 8px;
            border-radius: 6px;
            display: inline-block;
            margin-bottom: 1rem;
        }

        .status-pill {
            padding: 4px 12px;
            border-radius: 12px;
            font-size: 0.75rem;
            font-weight: 700;
            text-transform: uppercase;
            border: 1px solid transparent;
        }

        .pill-online { background: rgba(0, 255, 204, 0.1); color: var(--success-mint); border-color: var(--success-mint); }
        .pill-offline { background: rgba(255, 77, 109, 0.1); color: var(--punch-red); border-color: var(--punch-red); }

        .service-description {
            color: rgba(255, 255, 255, 0.5);
            font-size: 0.9rem;
            margin-bottom: 1.5rem;
            min-height: 40px;
            flex-grow: 1;
        }

        .metric-item {
            display: flex;
            align-items: center;
            gap: 10px;
            color: rgba(255, 255, 255, 0.7);
            font-size: 0.9rem;
            margin-bottom: 8px;
        }

        .metric-icon { color: var(--neon-blue); width: 20px; text-align: center; }

        .card-actions {
            display: flex;
            gap: 10px;
            margin-top: 20px;
        }

        /* Estilos para botones de tarjetas (JS classes) */
        .action-btn-small {
            flex: 1;
            padding: 8px 12px;
            border-radius: 12px;
            font-weight: 600;
            font-family: var(--font-tech);
            font-size: 0.8rem;
            text-align: center;
            text-decoration: none;
            transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 6px;
            border: 1px solid var(--glass-border);
            cursor: pointer;
            background: rgba(255, 255, 255, 0.03);
            color: rgba(255, 255, 255, 0.6);
            backdrop-filter: blur(4px);
        }

        .action-btn-small:hover:not(:disabled) {
            transform: translateY(-3px) scale(1.02);
            background: rgba(255, 255, 255, 0.08);
            color: #fff;
            border-color: rgba(255, 255, 255, 0.2);
        }

        .btn-ping {
            background: rgba(0, 210, 255, 0.05);
            color: var(--neon-blue);
            border-color: rgba(0, 210, 255, 0.2);
            flex: 2; /* Más ancho para el botón principal */
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.2);
        }
        
        .btn-ping:hover:not(:disabled) {
            background: var(--gradient-neon);
            color: #fff !important;
            box-shadow: var(--shadow-neon);
            border-color: transparent;
        }

        .btn-history:hover:not(:disabled) {
            color: var(--neon-indigo) !important;
            border-color: var(--neon-indigo);
            background: rgba(110, 64, 255, 0.1);
            box-shadow: 0 0 15px rgba(110, 64, 255, 0.3);
        }

        .btn-edit:hover:not(:disabled) {
            color: var(--warning-amber) !important;
            border-color: var(--warning-amber);
            background: rgba(255, 183, 3, 0.1);
            box-shadow: 0 0 15px rgba(255, 183, 3, 0.3);
        }

        .btn-delete:hover:not(:disabled) {
            color: var(--punch-red) !important;
            border-color: var(--punch-red);
            background: rgba(255, 77, 109, 0.1);
            box-shadow: 0 0 15px rgba(255, 77, 109, 0.3);
        }

        .action-btn-small:disabled {
            opacity: 0.3;
            cursor: not-allowed;
            filter: grayscale(1);
        }

        /* Status Colors and Glows */
        .status-up {
            border-color: rgba(0, 255, 204, 0.3) !important;
        }
        .status-up .card-status-line {
            background: var(--success-mint);
            box-shadow: 0 0 15px var(--success-mint);
        }
        .status-up .status-pill {
            background: rgba(0, 255, 204, 0.1);
            color: var(--success-mint);
            border-color: rgba(0, 255, 204, 0.2);
        }

        .status-down {
            border-color: rgba(255, 77, 109, 0.3) !important;
        }
        .status-down .card-status-line {
            background: var(--punch-red);
            box-shadow: 0 0 15px var(--punch-red);
        }
        .status-down .status-pill {
            background: rgba(255, 77, 109, 0.1);
            color: var(--punch-red);
            border-color: rgba(255, 77, 109, 0.2);
        }

        .status-slow {
            border-color: rgba(255, 183, 3, 0.3) !important;
        }
        .status-slow .card-status-line {
            background: var(--warning-amber);
            box-shadow: 0 0 15px var(--warning-amber);
        }
        .status-slow .status-pill {
            background: rgba(255, 183, 3, 0.1);
            color: var(--warning-amber);
            border-color: rgba(255, 183, 3, 0.2);
        }

        .status-unknown {
            border-color: rgba(255, 255, 255, 0.1) !important;
        }
        .status-unknown .card-status-line {
            background: rgba(255, 255, 255, 0.2);
        }
        .status-unknown .status-pill {
            background: rgba(255, 255, 255, 0.05);
            color: rgba(255, 255, 255, 0.4);
            border-color: rgba(255, 255, 255, 0.1);
        }

        .service-card.inactive-service {
            opacity: 0.6;
            filter: grayscale(0.5);
            border-style: dashed;
        }
        .service-card.inactive-service .card-status-line {
            background: #444;
            box-shadow: none;
        }

        /* Mantener compatibilidad con botones de cabecera */
        .btn-action-premium {
            padding: 10px 20px;
            border-radius: 12px;
            font-weight: 600;
            font-family: var(--font-tech);
            font-size: 0.9rem;
            transition: all 0.3s ease;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            border: none;
            cursor: pointer;
            box-shadow: var(--shadow-md);
        }

        .btn-ping-premium { background: var(--gradient-neon); color: #fff; }
        .btn-ping-premium:hover { transform: translateY(-2px); box-shadow: var(--shadow-neon); }

        /* Categoría Tab / Layout */
        .services-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
            gap: 24px;
        }

        /* Buscador / Filtros */
        .filter-section-premium {
            background: rgba(255, 255, 255, 0.03);
            border: 1px solid var(--glass-border);
            border-radius: 20px;
            padding: 20px;
            margin-bottom: 40px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 20px;
        }

        .search-wrapper {
            position: relative;
            flex: 1;
            min-width: 300px;
        }

        .form-control-premium {
            background: rgba(0, 0, 0, 0.2);
            border: 1px solid var(--glass-border);
            color: #fff;
            border-radius: 14px;
            padding: 12px 20px 12px 45px;
            width: 100%;
            transition: all 0.3s ease;
        }

        .form-control-premium:focus {
            outline: none;
            background: rgba(0, 0, 0, 0.3);
            border-color: var(--neon-blue);
            box-shadow: 0 0 15px rgba(0, 210, 255, 0.2);
        }

        .search-icon {
            position: absolute;
            left: 15px;
            top: 50%;
            transform: translateY(-50%);
            color: rgba(255, 255, 255, 0.3);
        }

        /* Nav Tabs Glass */
        .nav-tabs-premium {
            border: none;
            gap: 10px;
            margin-bottom: 30px;
        }

        .nav-tabs-premium .nav-link {
            background: rgba(255, 255, 255, 0.03);
            border: 1px solid var(--glass-border);
            color: rgba(255, 255, 255, 0.5);
            border-radius: 14px;
            padding: 12px 20px;
            font-family: var(--font-tech);
            font-weight: 600;
            transition: all 0.3s ease;
        }

        .nav-tabs-premium .nav-link.active {
            background: var(--gradient-neon);
            color: #fff;
            border-color: transparent;
            box-shadow: var(--shadow-neon);
        }

        /* Modal Styles Refined */
        .modal-content-premium {
            background: var(--space-surface);
            border: 1px solid var(--glass-border);
            border-radius: 24px;
            color: #fff;
        }

        /* Loading Animation Shimmer */
        @keyframes shimmer {
            0% { background-position: -200% 0; }
            100% { background-position: 200% 0; }
        }
        .status-loading .card-status-line {
            background: linear-gradient(90deg, var(--neon-blue), var(--neon-indigo), var(--neon-blue));
            background-size: 200% 100%;
            animation: shimmer 1.5s infinite linear;
        }

        @media (max-width: 768px) {
            .stats-container {
                flex-direction: column;
                gap: 20px;
            }
            .filter-section-premium {
                flex-direction: column;
                align-items: stretch;
            }
            .search-wrapper {
                min-width: 100%;
            }
        }

        /* Add New Card */
        .add-service-card {
            border: 2px dashed rgba(255, 255, 255, 0.2);
            border-radius: 24px;
            display: flex;
            align-items: center;
            justify-content: center;
            background: rgba(255, 255, 255, 0.03);
            cursor: pointer;
            min-height: 200px;
            transition: all 0.3s ease;
            height: 100%;
        }

        .add-service-card:hover {
            border-color: var(--neon-blue);
            background: rgba(0, 210, 255, 0.05);
            box-shadow: 0 0 15px rgba(0, 210, 255, 0.2);
        }

        .add-content {
            text-align: center;
            color: rgba(255, 255, 255, 0.6);
        }

        .add-content i {
            font-size: 2.5rem;
            margin-bottom: 0.5rem;
            opacity: 0.7;
            color: var(--neon-blue);
        }

        .add-content p {
            font-size: 0.9rem;
            margin: 0;
            font-weight: 600;
        }

        /* Loading Overlay */
        .card-loading-overlay {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(25, 25, 35, 0.95); /* Darker overlay for premium theme */
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            z-index: 10;
            border-radius: 24px; /* Match card border-radius */
        }

        .card-loading-overlay .spinner {
            width: 40px;
            height: 40px;
            border: 4px solid rgba(0, 210, 255, 0.2); /* Neon blue spinner */
            border-top-color: var(--neon-blue);
            border-radius: 50%;
            animation: spin 0.8s linear infinite;
        }

        .card-loading-overlay p {
            margin-top: 1rem;
            color: var(--neon-blue);
            font-weight: 600;
            font-size: 0.9rem;
        }

        @keyframes spin {
            to {
                transform: rotate(360deg);
            }
        }

        /* Responsive */
        @media (max-width: 768px) {
            .services-header {
                flex-direction: column;
                align-items: flex-start;
                gap: 1rem;
            }

            .header-actions {
                width: 100%;
                flex-direction: column;
            }

            .btn-action {
                width: 100%;
                justify-content: center;
            }

            .services-grid {
                grid-template-columns: 1fr;
            }
        }

        /* Category Badges (para vista "Todos") */
        .category-badge {
            position: absolute;
            top: 12px;
            right: 12px;
            padding: 0.25rem 0.6rem;
            border-radius: 12px;
            font-size: 0.7rem;
            font-weight: 600;
            text-transform: uppercase;
            z-index: 2;
            color: white;
            box-shadow: 0 2px 8px rgba(0,0,0,0.2);
        }

        .category-servicios {
            background-color: var(--neon-blue);
        }

        .category-terminales {
            background-color: var(--neon-indigo);
        }

        .category-balanzas {
            background-color: var(--punch-red);
        }

        .category-otros {
            background-color: var(--text-secondary);
        }

        /* Branch Selector */
        .branch-selector {
            background: var(--glass-bg);
            border: 1px solid var(--glass-border);
            border-radius: 20px;
            padding: 1rem;
            box-shadow: var(--glass-shadow);
            margin-bottom: 20px;
        }

        .branch-selector label {
            font-weight: 600;
            color: #fff;
            margin-bottom: 0.5rem;
            font-family: var(--font-tech);
        }

        .branch-selector .form-select {
            background: rgba(0, 0, 0, 0.2);
            border: 1px solid var(--glass-border);
            color: #fff;
            border-radius: 12px;
            padding: 0.6rem 1rem;
            appearance: none; /* Remove default arrow */
            -webkit-appearance: none;
            -moz-appearance: none;
            background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 16 16'%3e%3cpath fill='none' stroke='%23ffffff' stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='M2 5l6 6 6-6'/%3e%3c/svg%3e");
            background-repeat: no-repeat;
            background-position: right 0.75rem center;
            background-size: 16px 12px;
        }

        .branch-selector .form-select option {
            background-color: var(--space-surface); /* Darker background for options */
            color: #fff;
        }

        /* Section Headers */
        .section-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            background: var(--glass-bg);
            border: 1px solid var(--glass-border);
            border-radius: 20px;
            padding: 1rem 1.5rem;
            box-shadow: var(--glass-shadow);
            margin-bottom: 20px;
        }

        .section-header h4 {
            margin: 0;
            font-size: 1.1rem;
            font-weight: 700;
            color: #fff;
            display: flex;
            align-items: center;
            gap: 0.5rem;
            font-family: var(--font-tech);
        }

        .section-actions {
            display: flex;
            gap: 8px;
        }

        .btn-cancel-ping {
            background: var(--gradient-danger);
            color: white;
            border: none;
            padding: 0.5rem 1rem;
            border-radius: 12px;
            font-weight: 600;
            font-size: 0.85rem;
            transition: var(--transition);
            display: inline-flex;
            align-items: center;
            gap: 6px;
            font-family: var(--font-tech);
            box-shadow: 0 4px 10px rgba(255, 77, 109, 0.3);
        }

        .btn-cancel-ping:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(255, 77, 109, 0.4);
        }

        /* Input Group for Search */
        .input-group-premium {
            position: relative;
            width: 100%;
            max-width: 300px;
        }

        .input-group-premium .form-control {
            background: rgba(0, 0, 0, 0.2);
            border: 1px solid var(--glass-border);
            color: #fff;
            border-radius: 12px;
            padding: 0.6rem 1rem 0.6rem 2.5rem; /* Adjust padding for icon */
            transition: all 0.3s ease;
        }


        .input-group-premium .form-control:focus {
            outline: none;
            background: rgba(0, 0, 0, 0.3);
            border-color: var(--neon-blue);
            box-shadow: 0 0 10px rgba(0, 210, 255, 0.2);
        }

        .input-group-premium .input-group-text {
            position: absolute;
            left: 10px;
            top: 50%;
            transform: translateY(-50%);
            background: transparent;
            border: none;
            color: rgba(255, 255, 255, 0.5);
            z-index: 1;
        }
    </style>

    <div class="services-container">
        <!-- Dashboard Header Premium -->
        <header class="filter-section-premium">
            <div class="title-section">
                <h2 class="text-white"><i class="fa-solid fa-heartbeat text-danger me-2"></i>Monitoreo</h2>
                <p class="mb-0">Control de disponibilidad en tiempo real</p>
            </div>
            
            <div class="search-wrapper">
                <i class="fa-solid fa-magnifying-glass search-icon"></i>
                <input type="text" id="serviceSearch" class="form-control-premium" placeholder="Buscar IP, nombre o dominio...">
            </div>

            <div class="header-actions d-flex gap-2">
                <button class="btn-action-premium btn-ping-premium" id="btnPingAll">
                    <i class="fa-solid fa-tower-broadcast"></i> Ping Todos
                </button>
                <button class="btn-action-premium btn-ping-premium" id="btnNewService" style="background: var(--gradient-neon); color: #fff;">
                    <i class="fa-solid fa-plus-circle"></i> Nuevo
                </button>
            </div>
        </header>

        <!-- Stats Grid Premium -->
        <section class="stats-container" id="statsContainer">
            <div class="stat-item">
                <div class="stat-value" id="statTotal">0</div>
                <div class="stat-label">Total</div>
            </div>
            <div class="stat-item">
                <div class="stat-value text-success" id="statOnline">0</div>
                <div class="stat-label">Online</div>
            </div>
            <div class="stat-item">
                <div class="stat-value text-danger" id="statOffline">0</div>
                <div class="stat-label">Offline</div>
            </div>
            <div class="stat-item">
                <div class="stat-value text-lavender" id="statUnknown">0</div>
                <div class="stat-label">Pendiente</div>
            </div>
        </section>

        <!-- Category Tabs Premium -->
        <ul class="nav nav-tabs-premium" id="categoryTabs" role="tablist">
            <li class="nav-item">
                <button class="nav-link active" id="todos-tab" data-bs-toggle="tab" data-bs-target="#todos-pane" data-category="todos">
                    <i class="fa-solid fa-border-all me-2"></i>Todos
                </button>
            </li>
            <li class="nav-item">
                <button class="nav-link" id="servicios-tab" data-bs-toggle="tab" data-bs-target="#servicios-pane" data-category="servicios">
                    <i class="fa-solid fa-server me-2"></i>Servicios
                </button>
            </li>
            <li class="nav-item">
                <button class="nav-link" id="terminales-tab" data-bs-toggle="tab" data-bs-target="#terminales-pane" data-category="terminales">
                    <i class="fa-solid fa-desktop me-2"></i>Terminales
                </button>
            </li>
            <li class="nav-item">
                <button class="nav-link" id="balanzas-tab" data-bs-toggle="tab" data-bs-target="#balanzas-pane" data-category="balanzas">
                    <i class="fa-solid fa-scale-balanced me-2"></i>Balanzas
                </button>
            </li>
            <li class="nav-item">
