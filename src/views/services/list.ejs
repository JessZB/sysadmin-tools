    <!-- Modal Crear/Editar Servicio Premium -->
    <div class="modal fade" id="modalServicio" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content modal-content-premium">
                <div class="modal-header border-bottom-0 p-4">
                    <h5 class="modal-title font-display fw-bold" id="modalTitulo">Configurar Servicio</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body p-4 pt-0">
                    <form id="formServicio">
                        <input type="hidden" id="servicioId">
                        <div class="mb-3">
                            <label class="form-label small text-lavender text-uppercase fw-bold">Nombre</label>
                            <input type="text" class="form-control form-control-premium" id="nombre" placeholder="Ej: Servidor Web" required>
                        </div>
                        <div class="mb-3">
                            <label class="form-label small text-lavender text-uppercase fw-bold">Host / IP</label>
                            <input type="text" class="form-control form-control-premium" id="host" placeholder="Ej: 192.168.1.1" required>
                        </div>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label small text-lavender text-uppercase fw-bold">Tipo</label>
                                <select class="form-select form-control-premium" id="tipo" required>
                                    <option value="ip">Dirección IP</option>
                                    <option value="url">URL/Dominio</option>
                                </select>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label small text-lavender text-uppercase fw-bold">Categoría</label>
                                <select class="form-select form-control-premium" id="categoria" required>
                                    <option value="servicios">Servicios</option>
                                    <option value="balanzas">Balanzas</option>
                                    <option value="otros">Otros</option>
                                </select>
                            </div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label small text-lavender text-uppercase fw-bold">Descripción</label>
                            <textarea class="form-control form-control-premium" id="descripcion" rows="2"></textarea>
                        </div>
                        <div class="form-check form-switch mt-3">
                            <input class="form-check-input" type="checkbox" id="activo" checked>
                            <label class="form-check-label text-white-50" for="activo">Monitoreo Activo</label>
                        </div>
                    </form>
                </div>
                <div class="modal-footer border-top-0 p-4">
                    <button type="button" class="btn btn-link text-white-50 text-decoration-none" data-bs-dismiss="modal">Cancelar</button>
                    <button type="button" class="btn-action-premium btn-ping-premium" id="btnSaveService" style="background: var(--gradient-neon); color: #fff; width: auto; padding-left: 30px; padding-right: 30px;">
                        <i class="fa-solid fa-save"></i> Guardar
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Modal Historial Premium -->
    <div class="modal fade" id="modalHistorial" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content modal-content-premium">
                <div class="modal-header border-bottom-0 p-4">
                    <h5 class="modal-title font-display fw-bold">
                        <i class="fa-solid fa-clock-rotate-left me-2 text-info"></i>Historial de Verificaciones
                    </h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body p-4 pt-0">
                    <h6 id="historialNombre" class="mb-4 text-white-50"></h6>
                    <div class="table-responsive">
                        <table class="table table-frosted mb-0">
                            <thead>
                                <tr>
                                    <th>Fecha/Hora</th>
                                    <th>Estado</th>
                                    <th>Latencia</th>
                                    <th>Pérdida</th>
                                    <th>Min/Max/Avg</th>
                                </tr>
                            </thead>
                            <tbody id="historialBody">
                                <tr>
                                    <td colspan="5" class="text-center p-4">Cargando registros...</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>

