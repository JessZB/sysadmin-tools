<%- include('../layout/header') %>

    <style>
        .dashboard-header {
            background: var(--glass-bg);
            backdrop-filter: blur(12px);
            padding: 30px;
            border-radius: 24px;
            border: 1px solid var(--glass-border);
            margin-bottom: 40px;
            box-shadow: var(--glass-shadow);
        }

        /* Tarjeta POS Premium */
        .pos-card {
            min-height: 220px;
            /* Reducido para ser más dinámico */
            padding: 20px;
            border-radius: 24px;
            background: var(--glass-bg);
            border: 1px solid var(--glass-border);
            position: relative;
            overflow: hidden;
            transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
            display: flex;
            flex-direction: column;
            align-items: center;
            text-align: center;
            box-shadow: var(--glass-shadow);
        }

        .pos-card:hover {
            transform: translateY(-8px);
            border-color: var(--neon-blue);
            box-shadow: 0 20px 40px rgba(0, 210, 255, 0.15);
        }

        /* Resplandor de Estados (Glow States) */
        .status-success {
            border-bottom: 4px solid var(--success-mint);
        }

        .status-success .pos-icon {
            color: var(--success-mint);
            filter: drop-shadow(0 0 8px var(--success-mint));
        }

        .status-error {
            border-bottom: 4px solid var(--punch-red);
            animation: glow-error 2s infinite ease-in-out;
        }

        .status-error .pos-icon {
            color: var(--punch-red);
            filter: drop-shadow(0 0 10px var(--punch-red));
        }

        .status-warning {
            border-bottom: 4px solid var(--warning-amber);
        }

        .status-warning .pos-icon {
            color: var(--warning-amber);
            filter: drop-shadow(0 0 8px var(--warning-amber));
        }

        @keyframes glow-error {

            0%,
            100% {
                box-shadow: 0 0 20px rgba(255, 77, 109, 0.2);
            }

            50% {
                box-shadow: 0 0 40px rgba(255, 77, 109, 0.4);
            }
        }

        .pos-icon {
            font-size: 3rem;
            margin-bottom: 12px;
            transition: transform 0.3s ease;
        }

        /* Botón Ver Detalles - Flujo Normal */
        .hover-overlay {
            width: 100%;
            display: flex;
            justify-content: center;
            margin-top: auto;
            /* Empuja el botón al fondo del contenedor flex */
            padding-top: 15px;
            transition: all 0.3s ease;
            z-index: 5;
        }

        .view-details-btn {
            background: var(--gradient-neon);
            color: white;
            border: none;
            padding: 8px 18px;
            border-radius: 12px;
            font-family: var(--font-display);
            font-weight: 600;
            font-size: 0.85rem;
            letter-spacing: 0.5px;
            box-shadow: var(--shadow-neon);
            transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        }

        .view-details-btn:hover {
            transform: scale(1.05);
            box-shadow: 0 0 20px rgba(0, 210, 255, 0.6);
            color: white;
        }

        /* Densidad de Tablas */
        .mini-job-table td,
        .mini-job-table th {
            padding: 4px 6px !important;
            line-height: 1.2 !important;
            vertical-align: middle;
            word-break: break-word;
            overflow: hidden;
            text-overflow: ellipsis;
            font-size: 0.75rem;
        }

        /* Sin padding — máxima densidad para vista detallada */
        .ultra-dense td,
        .ultra-dense th {
            padding: 2px 4px !important;
            line-height: 1.1 !important;
        }

        .mini-job-table .badge {
            font-size: 0.7rem;
            padding: 3px 6px;
        }

        /* Server Card Refinamiento */
        .server-card {
            background: linear-gradient(135deg, rgba(0, 210, 255, 0.08), transparent);
            border-left: 4px solid var(--neon-blue);
            min-height: 180px !important;
            padding-bottom: 20px !important;
        }

        .server-card .hover-overlay {
            justify-content: flex-end;
            padding-top: 0;
            margin-top: 5px;
        }

        /* Contenedor de Badges de Moneda */
        .currency-badges {
            display: flex;
            flex-wrap: wrap;
            gap: 6px;
            justify-content: center;
            margin-top: 12px;
            margin-bottom: 5px;
            width: 100%;
        }

        .currency-badges .badge {
            font-family: var(--font-display);
            font-weight: 500;
            font-size: 0.75rem;
            padding: 5px 10px;
            border-radius: 8px;
            border: 1px solid rgba(255, 255, 255, 0.1);
        }

        .ls-1 {
            letter-spacing: 0.1em;
        }

        /* Contraste Global de Textos */
        .text-muted {
            color: rgba(255, 255, 255, 0.5) !important;
        }
    </style>



    <div class="dashboard-header d-flex justify-content-between align-items-center sticky-top" style="z-index: 1000;">
        <div>
            <h3 class="m-0"><i class="fa-solid fa-server me-2" aria-hidden="true"></i>Monitor POS</h3>

            <% if (user.role==='admin' ) { %>
                <div class="mt-2 d-flex align-items-center">
                    <label class="small text-muted me-2">Viendo:</label>
                    <select class="form-select form-select-sm" id="branchSelector" style="width: 250px;"
                        onchange="cambiarSucursal()">
                        <option value="" selected>-- No seleccionado --</option>
                        <option value="all">-- Todas las Sucursales --</option>
                    </select>
                </div>
                <% } else { %>
                    <small class="text-muted">Sucursal Actual: <strong>
                            <%= user.branch_name || 'Mi Sucursal' %>
                        </strong></small>
                    <% } %>
        </div>

        <div class="d-flex align-items-center gap-2 gap-md-3 flex-wrap justify-content-end">
            <div class="text-end">
                <small class="text-muted d-block" style="font-size: 0.7rem;">AUTO-REFRESH</small>
                <span class="badge btn-frosted border border-white border-opacity-10 text-neon-blue timer-badge"
                    id="countdownTimer" title="Click para pausar/reanudar">
                    05:00
                </span>
            </div>
            <button class="btn btn-frosted border border-white border-opacity-10 text-white" id="btnScreenshot"
                title="Capturar vista actual como imagen">
                <i class="fa-solid fa-camera me-1"></i> <span class="d-none d-md-inline">Capturar</span>
            </button>
            <button class="btn btn-primary" id="btnGlobalRefresh">
                <i class="fa-solid fa-arrows-rotate me-1"></i> <span class="d-none d-md-inline">Refrescar</span>
            </button>
        </div>
    </div>

    <ul class="nav nav-tabs mb-4 border-0 glass-effect p-1 rounded-pill" id="viewTabs" role="tablist"
        style="width: fit-content;">
        <li class="nav-item" role="presentation">
            <button class="nav-link active border-0 rounded-pill px-4 py-2" id="grid-tab" data-bs-toggle="tab"
                data-bs-target="#grid-view" type="button" role="tab">
                <i class="fa-solid fa-border-all me-2"></i>Vista General (Cajas)
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link border-0 rounded-pill px-4 py-2" id="matrix-tab" data-bs-toggle="tab"
                data-bs-target="#matrix-view" type="button" role="tab">
                <i class="fa-solid fa-list-check me-2" aria-hidden="true"></i>Vista Detallada (Jobs)
            </button>
        </li>
    </ul>

    <div class="tab-content" id="dashboardContent">

        <div class="tab-pane fade show active" id="grid-view" role="tabpanel">

            <div class="mb-4">
                <h6 class="text-uppercase text-muted fw-bold small ls-1"><i
                        class="fa-solid fa-server me-2"></i>Infraestructura Core</h6>
                <div class="row g-4" id="server-grid">
                </div>
            </div>

            <hr class="my-4 opacity-25">

            <div>
                <h6 class="text-uppercase text-muted fw-bold small ls-1"><i
                        class="fa-solid fa-cash-register me-2"></i>Terminales POS</h6>
                <div class="row g-4" id="pos-grid">
                    <div class="col-12 text-center py-5">
                        <div class="spinner-border text-primary"></div>
                    </div>
                </div>
            </div>
        </div>

        <div class="tab-pane fade" id="matrix-view" role="tabpanel">
            <div class="row">
                <div class="mb-4 col-xl-6">
                    <h6 class="text-uppercase text-muted fw-bold small ls-1">Servidor Principal</h6>
                    <div class="row g-4" id="server-matrix"></div>
                </div>

                <div class="col-xl-6">
                    <h6 class="text-uppercase text-muted fw-bold small ls-1">Detalle POS</h6>
                    <div
                        class="card glass-effect border-opacity-10 rounded-4 overflow-hidden border border-white border-opacity-5">
                        <div class="card-body p-0">
                            <table class="table table-sm mb-0 mini-job-table ultra-dense table-frosted align-middle"
                                style="table-layout: fixed; width: 100%;">
                                <thead class="text-center sticky-top">
                                    <tr>
                                        <th style="width: 12%;">Terminal</th>
                                        <th style="width: 22%;">Nombre</th>
                                        <th style="width: 12%;">Estado</th>
                                        <th style="width: 14%;">Ejecución</th>
                                        <th style="width: 22%;">Última ejecución</th>
                                        <th style="width: 18%;">Duración</th>
                                    </tr>
                                </thead>
                                <tbody id="matrix-grid">
                                    <tr>
                                        <td colspan="6" class="text-center py-3 text-muted">Cargando…</td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </div>

