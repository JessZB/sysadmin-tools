    <div class="modal fade" id="detailsModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-lg modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header glass-effect border-bottom-0 p-4" id="modalHeader">
                    <h5 class="modal-title font-display fw-bold" id="modalTitle">Cargando…</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"
                        aria-label="Cerrar"></button>
                </div>
                <div class="modal-body">
                    <div class="d-flex justify-content-between mb-3 border-bottom border-white border-opacity-5 pb-2">
                        <span id="modalIp" class="text-white-50 small"></span>
                        <span id="modalId" class="fw-bold text-white small"></span>
                    </div>

                    <div class="table-responsive">
                        <table class="table table-frosted align-middle">
                            <thead class="text-center">
                                <tr>
                                    <th>Estado</th>
                                    <th>Job</th>
                                    <th>Duración / Inicio</th>
                                    <th>Mensaje</th>
                                    <th>Acción</th>
                                </tr>
                            </thead>
                            <tbody id="jobsTableBody" class="text-center"></tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="modal fade" id="historyModal" tabindex="-1" aria-hidden="true" style="z-index: 1060;">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header glass-effect border-bottom-0 p-4">
                    <div>
                        <h5 class="modal-title font-display fw-bold" id="historyJobTitle">Historial</h5>
                        <small class="text-white-50" id="historyTerminalName">-</small>
                    </div>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body p-0">
                    <div class="table-responsive">
                        <table class="table table-frosted mb-0" style="font-size: 0.9rem;">
                            <thead class="sticky-top">
                                <tr>
                                    <th>Fecha</th>
                                    <th>Estado</th>
                                    <th>Duración</th>
                                    <th>Mensaje</th>
                                </tr>
                            </thead>
                            <tbody id="historyTableBody">
                                <tr>
                                    <td colspan="4" class="text-center py-3">Cargando...</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
                <div class="modal-footer border-top-0 p-4">
                    <button type="button" class="btn btn-frosted border border-white border-opacity-10 text-white"
                        data-bs-dismiss="modal"
                        style="width: auto; padding-left: 30px; padding-right: 30px;">Cerrar</button>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/html2canvas@1.4.1/dist/html2canvas.min.js"></script>
    <%- include('../layout/footer') %>