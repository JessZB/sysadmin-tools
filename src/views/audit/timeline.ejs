<%- include('../layout/header') %>

    <div class="container-fluid py-4">
        <div class="row mb-4">
            <div class="col px-4">
                <h3 class="fw-bold text-white font-display"><i
                        class="fa-solid fa-clock-rotate-left me-2 text-primary"></i>Auditoría de Movimientos</h3>
                <p class="text-white-50 small text-uppercase ls-1">Registro histórico de acciones y seguridad</p>
            </div>
        </div>

        <div class="row justify-content-center">
            <div class="col-lg-12">
                <ul class="nav nav-tabs mb-4 border-0 glass-effect p-1 rounded-pill" id="auditTabs" role="tablist"
                    style="width: fit-content; margin-left: auto; margin-right: auto;">
                    <li class="nav-item" role="presentation">
                        <button class="nav-link active border-0 rounded-pill px-4 py-2" id="timeline-tab"
                            data-bs-toggle="tab" data-bs-target="#timeline-view" type="button" role="tab">
                            <i class="fa-solid fa-stream me-2"></i>Vista Timeline
                        </button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link border-0 rounded-pill px-4 py-2" id="table-tab" data-bs-toggle="tab"
                            data-bs-target="#table-view" type="button" role="tab">
                            <i class="fa-solid fa-table me-2"></i>Vista Tabla
                        </button>
                    </li>
                </ul>

                <div class="tab-content" id="auditTabsContent">

                    <!-- TAB 1: TIMELINE VIEW -->
                    <div class="tab-pane fade show active" id="timeline-view" role="tabpanel">
                        <div class="row justify-content-center">
                            <div class="col-lg-10">

                                <% if (logs.length===0) { %>
                                    <div
                                        class="glass-effect text-center p-5 rounded-4 border border-white border-opacity-10">
                                        <i class="fa-solid fa-wind fa-3x mb-3 text-white-50 opacity-25"></i>
                                        <p class="text-white-50">No hay registros de actividad aún.</p>
                                    </div>
                                    <% } %>

                                        <div class="timeline">
                                            <% logs.forEach(function(log) { %>
                                                <div class="timeline-item">
                                                    <div class="timeline-date text-end pe-4 d-none d-md-block">
                                                        <% var d=new Date(log.created_at); var
                                                            dateStr=d.toLocaleDateString(); var
                                                            timeStr=d.toLocaleTimeString([], {hour: '2-digit' ,
                                                            minute:'2-digit'}); %>
                                                            <div class="fw-bold text-white small">
                                                                <%= dateStr %>
                                                            </div>
                                                            <div class="text-white-50 x-small mt-1">
                                                                <%= timeStr %>
                                                            </div>
                                                    </div>

                                                    <div class="timeline-marker">
                                                        <div
                                                            class="marker-dot shadow-neon border-0 bg-primary bg-opacity-75">
                                                            <i class="fa-solid <%= getIcon(log.action) %> text-white"
                                                                style="font-size: 0.8rem;"></i>
                                                        </div>
                                                        <div class="marker-line bg-white bg-opacity-10"></div>
                                                    </div>

                                                    <div
                                                        class="timeline-content card glass-effect mb-4 border-opacity-10 shadow-sm">
                                                        <div class="card-body p-4">
                                                            <div
                                                                class="d-flex justify-content-between align-items-center mb-2">
                                                                <h6
                                                                    class="card-title fw-bold mb-0 text-white font-display">
                                                                    <span class="text-primary opacity-75">
                                                                        <%= log.action %>
                                                                    </span>
                                                                    <span class="ms-1">
                                                                        <%= log.entity %>
                                                                    </span>
                                                                </h6>
                                                                <small class="text-white-50 x-small d-md-none">
                                                                    <%= dateStr %> | <%= timeStr %>
                                                                </small>
                                                            </div>

                                                            <p class="card-text mb-3 text-white-50 small ls-05">
                                                                <%= log.details %>
                                                            </p>

                                                            <div
                                                                class="d-flex justify-content-between align-items-center mt-3 border-top border-white border-opacity-5 pt-3">
                                                                <small class="text-white-50 x-small">
                                                                    <i
                                                                        class="fa-solid fa-user me-1 text-primary opacity-50"></i>
                                                                    <strong class="text-white">
                                                                        <%= log.username %>
                                                                    </strong>
                                                                    <span
                                                                        class="badge rounded-pill bg-white bg-opacity-5 text-white-50 border border-white border-opacity-10 ms-1"
                                                                        style="font-size: 0.65rem;">
                                                                        <%= log.role %>
                                                                    </span>
                                                                </small>

                                                                <small class="text-white-50 x-small"
                                                                    title="IP: <%= log.ip_address %>">
                                                                    <% if(log.branch_name) { %>
                                                                        <i
                                                                            class="fa-solid fa-building me-1 text-primary opacity-50"></i>
                                                                        <%= log.branch_name %>
                                                                            <% } else { %>
                                                                                <i
                                                                                    class="fa-solid fa-globe text-primary opacity-50"></i>
                                                                                Global
                                                                                <% } %>
                                                                </small>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                                <% }); %>
                                        </div>
                            </div>
                        </div>
                    </div>

                    <!-- TAB 2: TABLE VIEW -->
                    <div class="tab-pane fade" id="table-view" role="tabpanel">
                        <div class="card glass-effect border-opacity-10 rounded-4 overflow-hidden">
                            <div class="card-body p-0">
                                <table id="tablaAuditoria" data-toggle="table" data-pagination="true"
                                    data-page-size="25" data-page-list="[10, 25, 50, 100]" data-search="true"
                                    data-search-highlight="true" data-show-refresh="true" data-show-columns="true"
                                    data-sort-name="created_at" data-sort-order="desc" data-icons-prefix="bi"
                                    data-icons="icons" class="table table-frosted align-middle mb-0">

                                    <thead>
                                        <tr>
                                            <th data-field="created_at" data-sortable="true"
                                                data-formatter="dateFormatter">Fecha / Hora</th>
                                            <th data-field="username" data-sortable="true"
                                                data-formatter="userFormatter">Usuario</th>
                                            <th data-field="action" data-sortable="true"
                                                data-formatter="actionFormatter">Acción</th>
                                            <th data-field="entity" data-sortable="true"
                                                data-formatter="entityFormatter">Entidad</th>
                                            <th data-field="details" data-sortable="false"
                                                data-formatter="detailsFormatter">Detalle</th>
                                            <th data-field="branch_name" data-sortable="true"
                                                data-formatter="branchFormatter">Sucursal / IP</th>
                                        </tr>
                                    </thead>

                                    <tbody>
                                        <% logs.forEach(function(log) { %>
                                            <tr data-created-at="<%= log.created_at %>"
                                                data-username="<%= log.username %>" data-role="<%= log.role %>"
                                                data-action="<%= log.action %>" data-entity="<%= log.entity %>"
                                                data-details="<%= log.details %>"
                                                data-branch-name="<%= log.branch_name || '' %>"
                                                data-ip-address="<%= log.ip_address %>">
                                                <td>
                                                    <%= log.created_at %>
                                                </td>
                                                <td>
                                                    <%= log.username %>
                                                </td>
                                                <td>
                                                    <%= log.action %>
                                                </td>
                                                <td>
                                                    <%= log.entity %>
                                                </td>
                                                <td>
                                                    <%= log.details %>
                                                </td>
                                                <td>
                                                    <%= log.branch_name || '' %>
                                                </td>
                                            </tr>
                                            <% }); %>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>

                </div>
            </div>
        </div>
    </div>

    <style>
        /* Estilos Timeline CSS */
        .timeline {
            position: relative;
            padding: 20px 0;
        }

        .timeline-item {
            display: flex;
            position: relative;
            margin-bottom: 25px;
        }

        .timeline-date {
            width: 140px;
            flex-shrink: 0;
            padding-top: 15px;
        }

        .timeline-marker {
            width: 60px;
            flex-shrink: 0;
            position: relative;
            display: flex;
            flex-direction: column;
            align-items: center;
        }

        .marker-dot {
            width: 32px;
            height: 32px;
            display: flex;
            align-items: center;
            justify-content: center;
            z-index: 2;
            border-radius: 50%;
            transition: all 0.3s ease;
        }

        .marker-line {
            flex-grow: 1;
            width: 2px;
            position: absolute;
            top: 36px;
            bottom: -30px;
            left: 50%;
            transform: translateX(-50%);
            z-index: 1;
        }

        .timeline-item:last-child .marker-line {
            display: none;
        }

        .timeline-content {
            flex-grow: 1;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }

        .timeline-content:hover {
            transform: translateX(10px);
            background: rgba(255, 255, 255, 0.08) !important;
            border-color: rgba(0, 210, 255, 0.3) !important;
        }

        /* Ajustes para Tabs Premium */
        .nav-tabs .nav-link {
            color: rgba(255, 255, 255, 0.5);
            font-size: 0.85rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            transition: all 0.3s ease;
        }

        .nav-tabs .nav-link.active {
            background: var(--neon-blue) !important;
            color: white !important;
            box-shadow: 0 4px 15px rgba(0, 210, 255, 0.4);
        }

        .x-small {
            font-size: 0.7rem;
        }

        .ls-05 {
            letter-spacing: 0.5px;
        }
    </style>

    <script>
        // Inyectar datos de auditoria de forma segura para el linter
        window.auditLogs = JSON.parse(decodeURIComponent('<%= encodeURIComponent(JSON.stringify(logs)) %>'));
    </script>

    <%- include('../layout/footer') %>