<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Acceso Denegado - 403</title>
    <link rel="icon" type="image/x-icon" href="/favicon.webp">
    <link href="/css/lib/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/lib/bootstrap-icons.css">
    <link href="/css/lib/font-awesome.css" rel="stylesheet">
    <link href="/css/custom-theme.css" rel="stylesheet">
    <style>
        body {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .error-code {
            font-size: 8rem;
            font-family: var(--font-display);
            font-weight: 800;
            background: linear-gradient(135deg, var(--punch-red), var(--warning-amber));
            -webkit-background-clip: text;
            background-clip: text;
            -webkit-text-fill-color: transparent;
            line-height: 1;
        }
    </style>
</head>

<body class="noise-overlay">
    <div class="text-center px-4" style="max-width: 500px;">
        <div class="error-code mb-3">403</div>
        <div class="glass-effect rounded-4 p-5 border border-white border-opacity-5">
            <i class="fa-solid fa-user-lock fa-2x text-warning mb-3"></i>
            <h4 class="text-white fw-bold font-display mb-3">Acceso Restringido</h4>
            <p class="text-white-50 mb-4">
                <%= typeof message !=='undefined' ? message
                    : 'No tienes permisos suficientes para acceder a esta sección.' %>
            </p>
            <div class="d-grid gap-2">
                <a href="/dashboard" class="btn btn-action-premium btn-ping-premium py-3">
                    <i class="fa-solid fa-arrow-left me-2"></i>Volver al Dashboard
                </a>
                <a href="/logout" class="btn btn-frosted border border-white border-opacity-10 text-white py-2">
                    Cerrar Sesión
                </a>
            </div>
        </div>
        <div class="text-white-50 mt-4" style="font-size: 0.7rem; opacity: 0.3;">SysAdmin Tool Suite</div>
    </div>
</body>

</html>