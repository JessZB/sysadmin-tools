<%- include('../layout/header') %>

    <div class="container-fluid py-5">
        <div class="row justify-content-center">
            <div class="col-lg-10 col-xl-8">
                <!-- Header Principal de la Sección -->
                <div class="d-flex justify-content-between align-items-center mb-4 p-3 glass-effect rounded-4 shadow-sm border border-white border-opacity-5">
                    <div>
                        <h2 class="text-white mb-0 font-display fw-bold">
                            <i class="bi bi-barcode me-2 text-primary"></i>Generador de Etiquetas
                        </h2>
                        <p class="text-white-50 small mb-0 mt-1">Sincronización de balanzas Dibal/Soles • Estándar EAN-13</p>
                    </div>
                    <div class="d-flex gap-2">
                        <button class="btn btn-frosted text-white border border-white border-opacity-10 px-3" id="view-records-button">
                            <i class="bi bi-clock-history me-1"></i> Historial
                        </button>
                    </div>
                </div>

                <div class="row">
                    <!-- Panel de Configuración -->
                    <div class="col-md-5">
                        <div class="card glass-effect border-opacity-10 rounded-4 overflow-hidden mb-4 border border-white border-opacity-5">
                            <div class="card-header border-bottom border-white border-opacity-5 bg-transparent p-4">
                                <h5 class="text-white font-display mb-0 small text-uppercase fw-bold ls-1">Configuración del Producto</h5>
                            </div>
                            <div class="card-body p-4">
                                <div class="mb-4">
                                    <label for="plu" class="form-label text-white-50 small fw-bold text-uppercase ls-1">
                                        <i class="bi bi-hash me-2 text-primary"></i>PLU de Referencia
                                    </label>
                                    <input type="text" class="form-control glass-effect border-opacity-10 text-white p-3 font-monospace" id="plu" maxlength="4" placeholder="Ej: 0001" value="0001">
                                    <div class="form-text text-white-50 x-small mt-2">Identificador único de 4 dígitos</div>
                                </div>

                                <div class="mb-4">
                                    <label for="weight" class="form-label text-white-50 small fw-bold text-uppercase ls-1">
                                        <i class="bi bi-speedometer2 me-2 text-primary"></i>Peso del Artículo (kg)
                                    </label>
                                    <div class="input-group">
                                        <input type="number" class="form-control glass-effect border-opacity-10 text-white p-3" id="weight" step="0.001" placeholder="0.000">
                                        <span class="input-group-text glass-effect border-opacity-10 text-white border-start-0">KG</span>
                                    </div>
                                    <div class="form-text text-white-50 x-small mt-2">Peso neto para cálculo de EAN</div>
                                </div>

                                <div class="d-grid gap-3">
                                    <button class="btn btn-action-premium btn-ping-premium py-3 font-display fw-bold" id="generate-button">
                                        <i class="bi bi-lightning-charge-fill me-2"></i>GENERAR EAN-13
                                    </button>
                                    <button class="btn btn-frosted border border-white border-opacity-10 text-white py-2 opacity-50" id="download-button" disabled>
                                        <i class="bi bi-download me-2"></i>Exportar como PNG
                                    </button>
                                </div>
                            </div>
                        </div>

                        <!-- Info Card -->
                        <div class="card glass-effect border-opacity-10 rounded-4 border border-white border-opacity-5">
                            <div class="card-body p-4">
                                <h6 class="text-primary small text-uppercase fw-bold ls-1 mb-3">
                                    <i class="bi bi-info-circle me-2"></i>Resumen Técnico
                                </h6>
                                <div class="x-small text-white-50 lh-lg">
                                    <div class="d-flex justify-content-between border-bottom border-white border-opacity-5 pb-1 mb-1">
                                        <span>Prefijo Balanza:</span>
                                        <span class="text-white">22</span>
                                    </div>
                                    <div class="d-flex justify-content-between border-bottom border-white border-opacity-5 pb-1 mb-1">
                                        <span>Dígitos Peso:</span>
                                        <span class="text-white">5 (Gramos)</span>
                                    </div>
                                    <div class="d-flex justify-content-between">
                                        <span>Check Digit:</span>
                                        <span class="text-white">Auto Mod-10</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Visualización del Código -->
                    <div class="col-md-7">
                        <div class="card glass-effect border-opacity-10 rounded-4 h-100 border border-white border-opacity-5 d-flex flex-column align-items-center justify-content-center p-5 text-center">
                            <div id="barcode-display-wrapper" class="d-none w-100">
                                <div class="bg-white p-4 rounded-4 shadow-lg mb-4 d-inline-block transition-base" style="transform: scale(1.1);">
                                    <canvas id="barcode"></canvas>
                                </div>
                                <h3 id="barcode-text" class="font-display fw-bold text-white ls-2 mb-2"></h3>
                                <p id="date-time" class="text-white-50 x-small font-monospace mb-0"></p>
                            </div>

                            <div id="barcode-placeholder" class="text-white-50 opacity-25">
                                <i class="bi bi-upc-scan" style="font-size: 5rem;"></i>
                                <p class="mt-3 font-display">Configure los datos y genere el código</p>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Historial Expandible -->
                <div class="row mt-4 d-none" id="record-list-container">
                    <div class="col-12">
                        <div class="card glass-effect border-opacity-10 rounded-4 border border-white border-opacity-5">
                            <div class="card-header border-bottom border-white border-opacity-5 bg-transparent p-4 d-flex justify-content-between align-items-center">
                                <h5 class="text-white font-display mb-0 small text-uppercase fw-bold ls-1">Registros Recientes</h5>
                                <button class="btn btn-sm btn-link text-white-50 text-decoration-none" id="btn-clear-history">Limpiar</button>
                            </div>
                            <div class="card-body p-4">
                                <div id="record-list" class="row g-3">
                                    <!-- Dinámico -->
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <style>
        .transition-base { transition: all 0.3s ease; }
        
        .record-card {
            background: rgba(255, 255, 255, 0.03);
            border: 1px solid rgba(255, 255, 255, 0.05);
            border-radius: 16px;
            padding: 15px;
            transition: all 0.2s ease;
        }

        .record-card:hover {
            background: rgba(255, 255, 255, 0.06);
            border-color: var(--neon-blue);
            transform: translateY(-3px);
            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.2);
        }

        #barcode {
            max-width: 100%;
            height: auto !important;
        }

        .x-small { font-size: 0.75rem; }
        .ls-2 { letter-spacing: 0.15em; }
    </style>
