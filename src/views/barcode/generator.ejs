    </style>

    <script src="https://cdn.jsdelivr.net/npm/jsbarcode@3.11.0/dist/JsBarcode.all.min.js"></script>
    <script>
        const pluInput = document.getElementById('plu');
        const weightInput = document.getElementById('weight');
        const barcodeCanvas = document.getElementById('barcode');
        const barcodeText = document.getElementById('barcode-text');
        const dateTimeText = document.getElementById('date-time');
        const recordList = document.getElementById('record-list');
        const recordListContainer = document.getElementById('record-list-container');
        const generateButton = document.getElementById('generate-button');
        const downloadButton = document.getElementById('download-button');
        const viewRecordsButton = document.getElementById('view-records-button');
        const displayWrapper = document.getElementById('barcode-display-wrapper');
        const placeholder = document.getElementById('barcode-placeholder');
        const clearHistoryBtn = document.getElementById('btn-clear-history');

        let records = [];
        let historialVisible = false;

        // Cargar registros desde localStorage si existen
        const savedRecords = localStorage.getItem('barcode_history');
        if (savedRecords) {
            records = JSON.parse(savedRecords);
        }

        generateButton.addEventListener('click', () => {
            const plu = pluInput.value.trim().padStart(4, '0');
            const weight = parseFloat(weightInput.value);

            if (!plu || isNaN(weight) || weight < 0 || weight >= 100) {
                Swal.fire({
                    icon: 'error',
                    title: 'Datos Inválidos',
                    text: 'El PLU debe ser numérico y el peso estar entre 0 y 99.999 kg.',
                    confirmButtonColor: 'var(--punch-red)'
                });
                return;
            }

            const barcodeValue = generateEAN13Barcode(plu, weight);
            displayBarcode(barcodeValue);
            addRecord(barcodeValue, weight);

            // UI Feedback
            displayWrapper.classList.remove('d-none');
            placeholder.classList.add('d-none');
            downloadButton.disabled = false;
            downloadButton.classList.remove('opacity-50');

            showSuccessToast('EAN-13 Generado: ' + barcodeValue);
        });

        function generateEAN13Barcode(plu, weight) {
            const prefix = "22";
            const pluPadded = plu.padStart(5, '0');
            const weightInGrams = Math.round(weight * 1000);
            const weightStr = weightInGrams.toString().padStart(5, '0');
            let barcodeBase = prefix + pluPadded + weightStr;
            const checkDigit = calculateEAN13CheckDigit(barcodeBase);
            return barcodeBase + checkDigit;
        }

        function calculateEAN13CheckDigit(code) {
            let sum = 0;
            for (let i = 0; i < 12; i++) {
                sum += parseInt(code[i]) * (i % 2 === 0 ? 1 : 3);
            }
            const mod = sum % 10;
            return mod === 0 ? 0 : 10 - mod;
        }

        function displayBarcode(barcodeValue) {
            JsBarcode(barcodeCanvas, barcodeValue, {
                format: 'EAN13',
                displayValue: false,
                fontSize: 20,
                background: "#ffffff",
                lineColor: "#000000",
                width: 2.5,
                height: 100,
                margin: 10
            });

            const now = new Date();
            barcodeText.textContent = barcodeValue.match(/.{1,4}/g).join(' '); // Formatear visualmente
            dateTimeText.textContent = 'TIMESTAMP: ' + now.toLocaleString('es-VE');
        }

        function addRecord(barcodeValue, weight) {
            records.unshift({
                barcode: barcodeValue,
                dateTime: new Date().toLocaleString('es-VE'),
                weight: weight.toFixed(3)
            });
            if (records.length > 12) records.pop();
            localStorage.setItem('barcode_history', JSON.stringify(records));
            if (historialVisible) displayRecords();
        }

        function displayRecords() {
            recordList.innerHTML = '';
            if (records.length === 0) {
                recordList.innerHTML = '<div class="col-12 text-center text-white-50 py-4"><i class="bi bi-inbox me-2"></i>No hay registros guardados</div>';
            } else {
                records.forEach(record => {
                    const col = document.createElement('div');
                    col.className = 'col-md-6 col-lg-4';
                    col.innerHTML = `
                        <div class="record-card role="button">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <span class="badge bg-primary bg-opacity-10 text-primary">${record.weight} KG</span>
                                <small class="text-white-50 font-monospace" style="font-size: 0.6rem;">${record.dateTime}</small>
                            </div>
                            <div class="font-monospace text-info fw-bold">${record.barcode}</div>
                        </div>
                    `;
                    col.addEventListener('click', () => {
                        const [plu, w] = extractInfoFromBarcode(record.barcode);
                        pluInput.value = plu;
                        weightInput.value = w;
                        generateButton.click();
                        window.scrollTo({ top: 0, behavior: 'smooth' });
                    });
                    recordList.appendChild(col);
                });
            }
        }

        function extractInfoFromBarcode(ean) {
            // 22 00001 00000 X
            const plu = parseInt(ean.substring(2, 7)).toString();
            const weight = (parseInt(ean.substring(7, 12)) / 1000).toFixed(3);
            return [plu, weight];
        }

        downloadButton.addEventListener('click', () => {
            const link = document.createElement('a');
            link.href = barcodeCanvas.toDataURL('image/png');
            link.download = `EAN13_${pluInput.value}_${Date.now()}.png`;
            link.click();
            showSuccessToast('Archivo PNG exportado con éxito');
        });

        viewRecordsButton.addEventListener('click', () => {
            historialVisible = !historialVisible;
            recordListContainer.classList.toggle('d-none', !historialVisible);
            viewRecordsButton.classList.toggle('btn-primary-custom', historialVisible);
            
            if (historialVisible) {
                displayRecords();
                recordListContainer.scrollIntoView({ behavior: 'smooth' });
            }
        });

        clearHistoryBtn?.addEventListener('click', () => {
            records = [];
            localStorage.removeItem('barcode_history');
            displayRecords();
            showInfoToast('Historial limpiado');
        });

        // Eventos de teclado
        [pluInput, weightInput].forEach(el => {
            el.addEventListener('keypress', (e) => {
                if (e.key === 'Enter') generateButton.click();
            });
        });
    </script>

    <%- include('../layout/footer') %>