<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Acceso | SysAdmin Suite</title>
    <link rel="icon" type="image/x-icon" href="/favicon.webp">
    <link href="/css/lib/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/lib/bootstrap-icons.css">
    <link href="/css/lib/font-awesome.css" rel="stylesheet">
    <link href="/css/custom-theme.css" rel="stylesheet">
    <style>
        /* =============================================
           LOGIN PAGE — Nothing Style
           Strict palette: space-indigo / lavender-grey
           / platinum / punch-red / flag-red
           ============================================= */

        html, body {
            height: 100%;
        }

        body {
            background-color: var(--space-indigo);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
            position: relative;
        }

        /* Dot matrix background (inherited from custom-theme via body::before) */

        /* Subtle red glow in corner — signature accent */
        body::after {
            content: "";
            position: fixed;
            bottom: -80px;
            right: -80px;
            width: 400px;
            height: 400px;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(217, 4, 41, 0.12) 0%, transparent 70%);
            pointer-events: none;
            z-index: 0;
        }

        /* ---- LAYOUT ---- */
        .login-wrapper {
            position: relative;
            z-index: 10;
            width: 100%;
            max-width: 420px;
            padding: 24px 20px;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 32px;
        }

        /* ---- BRAND HEADER ---- */
        .brand-block {
            text-align: center;
        }

        .brand-logo {
            font-family: var(--font-tech);
            font-size: 2.2rem;
            color: var(--platinum);
            letter-spacing: -1px;
            line-height: 1;
            margin-bottom: 8px;
        }

        .brand-logo span {
            color: var(--lavender-grey);
        }

        .brand-tagline {
            font-family: var(--font-tech);
            font-size: 0.6rem;
            color: var(--lavender-grey);
            text-transform: uppercase;
            letter-spacing: 3px;
            opacity: 0.7;
        }

        /* Red accent line under brand */
        .brand-rule {
            width: 40px;
            height: 2px;
            background: var(--flag-red);
            margin: 12px auto 0;
        }

        /* ---- CARD ---- */
        .login-card {
            width: 100%;
            background: var(--glass-bg);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            border: 1px solid var(--glass-border);
            border-radius: 4px; /* Orthogonal — Nothing Style */
            border-top: 3px solid var(--flag-red);
            padding: 2.5rem 2rem;
            position: relative;
            overflow: hidden;
        }

        /* Corner dot decoration */
        .login-card::before {
            content: "";
            position: absolute;
            top: 0;
            right: 0;
            width: 80px;
            height: 80px;
            background: radial-gradient(circle at top right, rgba(217, 4, 41, 0.08), transparent 70%);
        }

        .card-eyebrow {
            font-family: var(--font-tech);
            font-size: 0.65rem;
            text-transform: uppercase;
            letter-spacing: 3px;
            color: var(--lavender-grey);
            margin-bottom: 6px;
        }

        .card-title {
            font-family: var(--font-tech);
            font-size: 1.4rem;
            color: var(--platinum);
            margin-bottom: 28px;
            line-height: 1.1;
        }

        /* ---- FORM FIELDS ---- */
        .field-group {
            margin-bottom: 24px;
        }

        .field-label {
            display: flex;
            align-items: center;
            gap: 8px;
            font-family: var(--font-tech);
            font-size: 0.65rem;
            text-transform: uppercase;
            letter-spacing: 2px;
            color: var(--lavender-grey);
            margin-bottom: 10px;
        }

        .field-label i {
            font-size: 0.8rem;
            color: var(--lavender-grey);
        }

        .field-input-wrap {
            display: flex;
            align-items: center;
            gap: 12px;
            border-bottom: 1px solid var(--lavender-grey);
            padding-bottom: 10px;
            transition: border-color 0.3s ease;
        }

        .field-input-wrap:focus-within {
            border-color: var(--punch-red);
            box-shadow: 0 4px 12px rgba(239, 35, 60, 0.1);
        }

        .field-input-wrap i {
            color: var(--lavender-grey);
            font-size: 1rem;
            flex-shrink: 0;
            transition: color 0.3s ease;
        }

        .field-input-wrap:focus-within i {
            color: var(--punch-red);
        }

        .field-input {
            background: transparent;
            border: none;
            outline: none;
            color: var(--platinum);
            font-family: var(--font-body);
            font-size: 1rem;
            width: 100%;
            padding: 0;
        }

        .field-input::placeholder {
            font-family: var(--font-tech);
            color: var(--lavender-grey);
            opacity: 0.5;
            font-size: 0.8rem;
            letter-spacing: 1px;
        }

        /* ---- ERROR ALERT ---- */
        .login-error {
            display: flex;
            align-items: center;
            gap: 10px;
            background: rgba(217, 4, 41, 0.08);
            border: 1px solid rgba(217, 4, 41, 0.3);
            border-left: 3px solid var(--flag-red);
            border-radius: 2px;
            padding: 12px 14px;
            margin-bottom: 20px;
            font-family: var(--font-body);
            font-size: 0.85rem;
            color: var(--punch-red);
        }

        .login-error i {
            flex-shrink: 0;
            font-size: 1rem;
        }

        /* ---- SUBMIT BUTTON ---- */
        .btn-login {
            width: 100%;
            padding: 14px 24px;
            background: var(--flag-red);
            color: var(--platinum);
            border: none;
            border-radius: 2px;
            font-family: var(--font-tech);
            font-size: 0.85rem;
            text-transform: uppercase;
            letter-spacing: 2px;
            cursor: pointer;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            margin-top: 8px;
            position: relative;
            overflow: hidden;
        }

        .btn-login::before {
            content: "";
            position: absolute;
            inset: 0;
            background: linear-gradient(135deg, rgba(255,255,255,0.07), transparent);
        }

        .btn-login:hover {
            background: var(--punch-red);
            box-shadow: 0 0 20px rgba(239, 35, 60, 0.35);
            transform: translateY(-2px);
        }

        .btn-login:active {
            transform: translateY(0);
            box-shadow: none;
        }

        .btn-login:disabled {
            opacity: 0.6;
            cursor: not-allowed;
            transform: none;
        }

        /* Spinner inside button */
        .btn-login .spinner-border {
            width: 1rem;
            height: 1rem;
            border-width: 2px;
        }

        /* ---- FOOTER ---- */
        .login-footer {
            text-align: center;
            font-family: var(--font-tech);
            font-size: 0.6rem;
            color: var(--lavender-grey);
            opacity: 0.5;
            letter-spacing: 1px;
            text-transform: uppercase;
        }

        /* ---- ENTRANCE ANIMATION ---- */
        @keyframes slide-up {
            from { opacity: 0; transform: translateY(24px); }
            to   { opacity: 1; transform: translateY(0); }
        }

        .brand-block { animation: slide-up 0.6s cubic-bezier(0.16, 1, 0.3, 1) both; }
        .login-card  { animation: slide-up 0.6s 0.1s cubic-bezier(0.16, 1, 0.3, 1) both; }
        .login-footer{ animation: slide-up 0.6s 0.2s cubic-bezier(0.16, 1, 0.3, 1) both; }
    </style>
</head>

<body class="noise-overlay">

    <div class="login-wrapper">

        <!-- Brand -->
        <div class="brand-block">
            <div class="brand-logo">
                <i class="fa-solid fa-bolt-lightning me-2" style="color: var(--flag-red);"></i>SYS<span>ADMIN</span>
            </div>
            <div class="brand-tagline">Infrastructure Management Suite</div>
            <div class="brand-rule"></div>
        </div>

        <!-- Login Card -->
        <div class="login-card">
            <div class="card-eyebrow">Autenticación de Acceso</div>
            <h1 class="card-title">Control de Acceso</h1>

            <!-- Error Alert (hidden by default) -->
            <div id="loginError" class="login-error d-none" role="alert">
                <i class="bi bi-shield-exclamation"></i>
                <span></span>
            </div>

            <form id="loginForm" autocomplete="off" novalidate>

                <!-- Username -->
                <div class="field-group">
                    <label for="username" class="field-label">
                        <i class="bi bi-person-badge"></i> Identificador
                    </label>
                    <div class="field-input-wrap">
                        <i class="bi bi-terminal"></i>
                        <input
                            type="text"
                            class="field-input"
                            id="username"
                            name="username"
                            placeholder="usuario_sys"
                            required
                            autofocus
                            autocomplete="username"
                        >
                    </div>
                </div>

                <!-- Password -->
                <div class="field-group">
                    <label for="password" class="field-label">
                        <i class="bi bi-key"></i> Contraseña
                    </label>
                    <div class="field-input-wrap">
                        <i class="bi bi-lock"></i>
                        <input
                            type="password"
                            class="field-input"
                            id="password"
                            name="password"
                            placeholder="••••••••"
                            required
                            autocomplete="current-password"
                        >
                    </div>
                </div>

                <button type="submit" class="btn-login" id="btnLogin">
                    <i class="bi bi-box-arrow-in-right"></i>
                    Ingresar al Sistema
                </button>

            </form>
        </div>

        <!-- Footer -->
        <div class="login-footer">
            &copy; 2025 SysAdmin Tool Suite &bull; Acceso Restringido
        </div>

    </div>

    <script src="/js/lib/sweetalert2@11.js"></script>
    <script src="/js/auth.client.js"></script>
</body>

</html>