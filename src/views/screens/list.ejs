<%- include('../layout/header') %>

    <div class="dashboard-header d-flex justify-content-between align-items-center mb-5 sticky-top" style="z-index: 1000; margin-top: -20px;">
        <div>
            <h2 class="text-white mb-0 font-display fw-bold">
                <i class="bi bi-tv me-2 text-primary"></i>Gestión de Pantallas
            </h2>
            <p class="text-white-50 small mb-0 mt-1">Monitoreo y control remoto de dispositivos de visualización</p>
        </div>
        <button class="btn btn-action-premium btn-ping-premium px-4" data-action="create-screen">
            <i class="bi bi-plus-lg me-2"></i>Añadir Pantalla
        </button>
    </div>

    <% if (screens.length===0) { %>
        <div class="glass-effect rounded-4 p-5 text-center border border-white border-opacity-5">
            <i class="bi bi-display fs-1 text-white-50 opacity-25 mb-3 d-block"></i>
            <h4 class="text-white">No hay pantallas registradas</h4>
            <p class="text-white-50">Comienza agregando un televisor LG, Samsung o dispositivo DLNA.</p>
            <button class="btn btn-action-premium btn-ping-premium mt-3" data-action="create-screen">
                <i class="bi bi-plus-lg me-2"></i>Configurar Primera Pantalla
            </button>
        </div>
    <% } else { %>
        <!-- Categorización de Pantallas -->
        <% 
            const lgScreens = screens.filter(s => s.device_type === 'browser' && s.name.toLowerCase().includes('lg'));
            const samsungScreens = screens.filter(s => s.device_type === 'browser' && !s.name.toLowerCase().includes('lg'));
            const dlnaScreens = screens.filter(s => s.device_type === 'dlna');
        %>

        <!-- Sección LG -->
        <% if (lgScreens.length > 0) { %>
            <div class="mb-5">
                <h6 class="text-uppercase text-lavender fw-bold small ls-1 mb-4">
                    <i class="bi bi-app-indicator text-primary me-2"></i>Televisores LG WebOS
                </h6>
                <div class="row g-4">
                    <% lgScreens.forEach(screen => { %>
                        <div class="col-md-6 col-lg-4">
                            <%- include('screen-card-component', { screen, type: 'lg', color: 'primary' }) %>
                        </div>
                    <% }) %>
                </div>
            </div>
        <% } %>

        <!-- Sección Samsung -->
        <% if (samsungScreens.length > 0) { %>
            <div class="mb-5">
                <h6 class="text-uppercase text-lavender fw-bold small ls-1 mb-4">
                    <i class="bi bi-app-indicator text-info me-2"></i>Televisores Samsung Tizen
                </h6>
                <div class="row g-4">
                    <% samsungScreens.forEach(screen => { %>
                        <div class="col-md-6 col-lg-4">
                            <%- include('screen-card-component', { screen, type: 'samsung', color: 'info' }) %>
                        </div>
                    <% }) %>
                </div>
            </div>
        <% } %>

        <!-- Sección DLNA -->
        <% if (dlnaScreens.length > 0) { %>
            <div class="mb-5">
                <h6 class="text-uppercase text-lavender fw-bold small ls-1 mb-4">
                    <i class="bi bi-app-indicator text-success me-2"></i>Dispositivos DLNA / Cast
                </h6>
                <div class="row g-4">
                    <% dlnaScreens.forEach(screen => { %>
                        <div class="col-md-6 col-lg-4">
                            <%- include('screen-card-component', { screen, type: 'dlna', color: 'success' }) %>
                        </div>
                    <% }) %>
                </div>
            </div>
        <% } %>

        <!-- Modales de Control (Fuera de la cuadrícula para evitar problemas de interacción) -->
        <% lgScreens.forEach(screen => { %>
            <%- include('lg-control-modal', { screen }) %>
        <% }) %>

        <% samsungScreens.forEach(screen => { %>
            <%- include('samsung-control-modal', { screen }) %>
        <% }) %>

        <% dlnaScreens.forEach(screen => { %>
            <%- include('dlna-control-modal', { screen: screen, mediaFiles: (typeof mediaFiles !== 'undefined' ? mediaFiles : []) }) %>
        <% }) %>
    <% } %>

    <%- include('screen-form-modal') %>


<style>
    .ls-1 { letter-spacing: 0.1em; }
    
    /* Animación para cards al cargar */
    .row {
        animation: fadeIn 0.5s ease-out forwards;
    }
    
    @keyframes fadeIn {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
    }
</style>

<%- include('../layout/footer') %>