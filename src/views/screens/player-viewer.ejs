<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= title %>
    </title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <style>
        body {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            padding: 20px;
        }

        .viewer-container {
            max-width: 1200px;
            margin: 0 auto;
        }

        .card {
            border-radius: 15px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3);
            margin-bottom: 20px;
        }

        .video-preview {
            background: #000;
            border-radius: 10px;
            overflow: hidden;
            position: relative;
            aspect-ratio: 16/9;
        }

        .video-preview video {
            width: 100%;
            height: 100%;
            object-fit: contain;
        }

        .progress-bar-custom {
            height: 8px;
            background: #e9ecef;
            border-radius: 4px;
            overflow: hidden;
            cursor: pointer;
        }

        .progress-fill {
            height: 100%;
            background: linear-gradient(90deg, #667eea 0%, #764ba2 100%);
            transition: width 0.3s ease;
        }

        .playlist-item {
            cursor: pointer;
            padding: 10px;
            border-radius: 8px;
            margin-bottom: 5px;
            transition: all 0.2s;
        }

        .playlist-item:hover {
            background: #f8f9fa;
        }

        .playlist-item.active {
            background: linear-gradient(90deg, #667eea 0%, #764ba2 100%);
            color: white;
        }

        .control-btn {
            width: 50px;
            height: 50px;
            border-radius: 50%;
            border: none;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            font-size: 20px;
            cursor: pointer;
            transition: transform 0.2s;
        }

        .control-btn:hover {
            transform: scale(1.1);
        }

        .status-badge {
            position: absolute;
            top: 10px;
            right: 10px;
            padding: 5px 15px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: bold;
        }

        .status-playing {
            background: #28a745;
            color: white;
        }

        .status-paused {
            background: #ffc107;
            color: #000;
        }

        .status-offline {
            background: #dc3545;
            color: white;
        }
    </style>
</head>

<body>
    <div class="viewer-container">
        <!-- Header -->
        <div class="card">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h3 class="mb-0"><i class="bi bi-tv"></i>
                            <%= screen.name %>
                        </h3>
                        <small class="text-lavender">Player Viewer - Monitoreo en Tiempo Real</small>
                    </div>
                    <div>
                        <span id="connectionStatus" class="badge bg-secondary">
                            <i class="bi bi-circle-fill"></i> Conectando...
                        </span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Video Preview & Info -->
        <div class="card">
            <div class="card-body">
                <div class="row">
                    <div class="col-lg-8">
                        <div class="video-preview">
                            <video id="previewVideo" controls muted></video>
                            <span id="playbackStatus" class="status-badge status-offline">
                                <i class="bi bi-circle-fill"></i> Sin reproducción
                            </span>
                        </div>
                    </div>
                    <div class="col-lg-4">
                        <h5>Información de Reproducción</h5>
                        <div class="mb-3">
                            <strong>Video Actual:</strong>
                            <p id="currentVideo" class="text-lavender">-</p>
                        </div>
                        <div class="mb-3">
                            <strong>Progreso:</strong>
                            <div class="progress-bar-custom" id="progressBar">
                                <div class="progress-fill" id="progressFill" style="width: 0%"></div>
                            </div>
                            <small class="text-lavender">
                                <span id="currentTime">0:00</span> / <span id="duration">0:00</span>
                            </small>
                        </div>
                        <div class="mb-3">
                            <strong>Modo Loop:</strong>
                            <span id="loopMode" class="badge bg-secondary">No</span>
                        </div>
                        <div class="mb-3">
                            <strong>Volumen:</strong>
                            <input type="range" class="form-range" id="volumeControl" min="0" max="100" value="100">
                            <small class="text-lavender"><span id="volumeValue">100</span>%</small>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Controls -->
        <div class="card">
            <div class="card-body">
                <h5>Controles de Reproducción</h5>
                <div class="d-flex justify-content-center gap-3 mt-3">
                    <button class="control-btn" data-action="sendCommand('previous')" title="Anterior">
                        <i class="bi bi-skip-start-fill"></i>
                    </button>
                    <button class="control-btn" id="playPauseBtn" data-action="togglePlayPause()" title="Play/Pause">
                        <i class="bi bi-play-fill"></i>
                    </button>
                    <button class="control-btn" data-action="sendCommand('next')" title="Siguiente">
                        <i class="bi bi-skip-end-fill"></i>
                    </button>
                </div>
            </div>
        </div>

        <!-- Playlist -->
        <div class="card">
            <div class="card-body">
                <h5>Playlist</h5>
                <div id="playlistContainer" class="mt-3">
                    <p class="text-lavender">No hay videos en la playlist</p>
                </div>
            </div>
        </div>

        <!-- Debug: Available Videos -->
        <% if (locals.mediaFiles && mediaFiles.length> 0) { %>
            <div class="card mt-3">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h5><i class="bi bi-info-circle"></i> Videos Disponibles en Servidor</h5>
                        <button class="btn btn-success btn-sm" data-action="playAllOnTV()">
                            <i class="bi bi-collection-play me-1"></i> Reproducir Todos
                        </button>
                    </div>
                    <small class="text-lavender d-block mb-2">Lista de archivos detectados en /public/media/videos</small>
                    <div class="list-group">
                        <% mediaFiles.forEach(function(file) { %>
                            <div
                                class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                                <span><i class="bi bi-file-earmark-play me-2"></i>
                                    <%= file %>
                                </span>
                                <button class="btn btn-sm btn-primary me-2" data-action="playOnTV('<%= file %>')">
                                    <i class="bi bi-play-fill"></i> Reproducir en TV
                                </button>
                                <a href="/media/videos/<%= encodeURIComponent(file) %>" target="_blank"
                                    class="btn btn-sm btn-outline-secondary">
                                    <i class="bi bi-box-arrow-up-right"></i> Ver
                                </a>
                            </div>
                            <% }); %>
                    </div>
                </div>
            </div>
            <% } %>
    </div>

    <!-- Hidden data container for safe JS injection -->
    <div id="serverData" data-videos='<%- JSON.stringify(mediaFiles || []) %>' style="display:none;"></div>

    <script src="/socket.io/socket.io.js"></script>
    <script>
        const screenId = '<%= screen.id %>';
        // Read data safely from DOM
        let availableVideos = [];
        try {
            const dataElement = document.getElementById('serverData');
            if (dataElement && dataElement.dataset.videos) {
                availableVideos = JSON.parse(dataElement.dataset.videos);
            }
        } catch (e) {
            console.error('Error parsing video list:', e);
        }

        let socket = null;
        let currentState = null;
        let isPaused = true;

        // Initialize WebSocket
        function initWebSocket() {
            socket = io();

            socket.on('connect', () => {
                console.log('🔌 Connected to WebSocket');
                updateConnectionStatus(true);
                socket.emit('viewer:join', screenId);
            });

            socket.on('disconnect', () => {
                console.log('❌ Disconnected from WebSocket');
                updateConnectionStatus(false);
            });

            socket.on('player:state', (state) => {
                console.log('📊 Player state received:', state);
                currentState = state;
                updateUI(state);
            });

            socket.on('player:progress', (data) => {
                updateProgress(data.currentTime, data.duration);
            });

            socket.on('player:videoChange', (data) => {
                updateCurrentVideo(data.currentVideo, data.currentIndex);
            });
        }

        // Update UI with player state
        function updateUI(state) {
            isPaused = state.paused;

            // Update current video
            document.getElementById('currentVideo').textContent = state.currentVideo || '-';

            // Update playback status
            const statusBadge = document.getElementById('playbackStatus');
            if (state.paused) {
                statusBadge.className = 'status-badge status-paused';
                statusBadge.innerHTML = '<i class="bi bi-pause-fill"></i> Pausado';
            } else {
                statusBadge.className = 'status-badge status-playing';
                statusBadge.innerHTML = '<i class="bi bi-play-fill"></i> Reproduciendo';
            }

            // Update play/pause button
            const playPauseBtn = document.getElementById('playPauseBtn');
            playPauseBtn.innerHTML = state.paused ? '<i class="bi bi-play-fill"></i>' : '<i class="bi bi-pause-fill"></i>';

            // Update progress
            updateProgress(state.currentTime, state.duration);

            // Update loop mode
            document.getElementById('loopMode').textContent = state.loopMode ? 'Sí' : 'No';
            document.getElementById('loopMode').className = state.loopMode ? 'badge bg-success' : 'badge bg-secondary';

            // Update volume
            const volumePercent = Math.round(state.volume * 100);
            document.getElementById('volumeControl').value = volumePercent;
            document.getElementById('volumeValue').textContent = volumePercent;

            // Update playlist
            updatePlaylist(state.playlist, state.currentIndex);

            // Update preview video
            if (state.currentVideo) {
                const videoUrl = `/media/videos/${encodeURIComponent(state.currentVideo)}`;
                const previewVideo = document.getElementById('previewVideo');

                // Check if source changed (handle absolute vs relative url)
                // Using includes or endsWith is safer than strict equality
                if (!previewVideo.src.includes(encodeURIComponent(state.currentVideo))) {
                    console.log('🔄 Loading new video in preview:', state.currentVideo);
                    previewVideo.src = videoUrl;
                    previewVideo.currentTime = state.currentTime;
                } else {
                    // Sync time only if desync > 2 seconds
                    if (Math.abs(previewVideo.currentTime - state.currentTime) > 2) {
                        previewVideo.currentTime = state.currentTime;
                    }
                }

                // Sync play state
                if (state.paused) {
                    previewVideo.pause();
                } else {
                    previewVideo.play().catch(e => { /* Ignore autoplay errors in preview */ });
                }
            }
        }

        // Update progress bar
        function updateProgress(currentTime, duration) {
            const current = formatTime(currentTime);
            const total = formatTime(duration);

            document.getElementById('currentTime').textContent = current;
            document.getElementById('duration').textContent = total;

            const percent = duration > 0 ? (currentTime / duration) * 100 : 0;
            document.getElementById('progressFill').style.width = percent + '%';
        }

        // Update current video
        function updateCurrentVideo(video, index) {
            document.getElementById('currentVideo').textContent = video || '-';
            if (currentState) {
                currentState.currentVideo = video;
                currentState.currentIndex = index;
                updatePlaylist(currentState.playlist, index);
            }
        }

        // Update playlist display
        function updatePlaylist(playlist, currentIndex) {
            const container = document.getElementById('playlistContainer');
            if (!playlist || playlist.length === 0) {
                container.innerHTML = '<p class="text-lavender">No hay videos en la playlist</p>';
                return;
            }

            container.innerHTML = playlist.map((video, index) => `
                <div class="playlist-item ${index === currentIndex ? 'active' : ''}" data-action="playVideo(${index})">
                    <i class="bi bi-${index === currentIndex ? 'play-circle-fill' : 'file-play'}"></i>
                    ${video}
                </div>
            `).join('');
        }

        // Update connection status
        function updateConnectionStatus(connected) {
            const badge = document.getElementById('connectionStatus');
            if (connected) {
                badge.className = 'badge bg-success';
                badge.innerHTML = '<i class="bi bi-circle-fill"></i> Conectado';
            } else {
                badge.className = 'badge bg-danger';
                badge.innerHTML = '<i class="bi bi-circle-fill"></i> Desconectado';
            }
        }

        // Format time (seconds to MM:SS)
        function formatTime(seconds) {
            if (!seconds || isNaN(seconds)) return '0:00';
            const mins = Math.floor(seconds / 60);
            const secs = Math.floor(seconds % 60);
            return `${mins}:${secs.toString().padStart(2, '0')}`;
        }

        // Send command to player
        function sendCommand(action, value) {
            if (!socket) return;
            socket.emit('player:command', { screenId, action, value });
        }

        // Toggle play/pause
        function togglePlayPause() {
            sendCommand(isPaused ? 'play' : 'pause');
        }

        // Play specific video
        function playVideo(index) {
            sendCommand('playIndex', index);
        }

        // Volume control
        document.getElementById('volumeControl').addEventListener('input', (e) => {
            const volume = parseInt(e.target.value) / 100;
            document.getElementById('volumeValue').textContent = e.target.value;
            sendCommand('setVolume', volume);
        });

        // Progress bar click to seek
        document.getElementById('progressBar').addEventListener('click', (e) => {
            if (!currentState || !currentState.duration) return;
            const rect = e.target.getBoundingClientRect();
            const percent = (e.clientX - rect.left) / rect.width;
            const time = percent * currentState.duration;
            sendCommand('seek', time);
        });

        // Play specific video on TV (from available list)
        function playOnTV(filename) {
            console.log('Enviando video al TV:', filename);
            sendCommand('setPlaylist', { playlist: [filename], loop: true });
            // Also update connection status just in case
            if (!socket.connected) initWebSocket();
        }

        // Initialize on load
        initWebSocket();

        // Play ALL videos on TV
        function playAllOnTV() {
            if (!availableVideos || availableVideos.length === 0) {
                alert('No hay videos disponibles');
                return;
            }
            console.log('Enviando todos los videos al TV:', availableVideos.length);
            sendCommand('setPlaylist', { playlist: availableVideos, loop: true });
            if (!socket.connected) initWebSocket();
        }
    </script>
</body>

</html>