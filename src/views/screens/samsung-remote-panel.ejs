<!-- Samsung Remote Panel Premium -->
<div class="remote-panel">
    <!-- Validar/Re-validar -->
    <button class="btn btn-action-premium btn-ping-premium w-100 mb-4 py-2" 
        data-action="validate" data-id="<%= screen.id %>" style="background: var(--gradient-neon); border: none;">
        <i class="bi bi-shield-check me-2"></i>
        <%= screen.client_token ? 'Re-validar Conexión' : 'Emparejar con TV' %>
    </button>

    <!-- Control Remoto Layout -->
    <div class="remote-layout glass-effect p-3 rounded-4 border border-white border-opacity-5">
        <h6 class="text-white-50 small text-uppercase fw-bold mb-3 ls-1 text-center">Pad de Navegación</h6>
        
        <!-- Power Controls -->
        <div class="row g-2 mb-4">
            <div class="col-6">
                <button class="btn btn-frosted border-success border-opacity-25 text-success w-100 py-2" 
                    data-action="power-on" data-id="<%= screen.id %>">
                    <i class="bi bi-lightning-charge-fill me-1"></i> ON
                </button>
            </div>
            <div class="col-6">
                <button class="btn btn-frosted border-danger border-opacity-25 text-danger w-100 py-2" 
                    data-action="power-off" data-id="<%= screen.id %>">
                    <i class="bi bi-power me-1"></i> OFF
                </button>
            </div>
        </div>

        <!-- Volume & Mute -->
        <div class="row g-2 mb-4">
            <div class="col-4">
                <button class="btn btn-frosted border-white border-opacity-10 text-white w-100" 
                    data-action="send-key" data-id="<%= screen.id %>" data-key="KEY_VOLUP" data-label="Vol+">
                    <i class="bi bi-volume-up"></i>
                </button>
            </div>
            <div class="col-4">
                <button class="btn btn-frosted border-white border-opacity-10 text-white w-100" 
                    data-action="send-key" data-id="<%= screen.id %>" data-key="KEY_VOLDOWN" data-label="Vol-">
                    <i class="bi bi-volume-down"></i>
                </button>
            </div>
            <div class="col-4">
                <button class="btn btn-frosted border-warning border-opacity-25 text-warning w-100" 
                    data-action="send-key" data-id="<%= screen.id %>" data-key="KEY_MUTE" data-label="Mute">
                    <i class="bi bi-volume-mute"></i>
                </button>
            </div>
        </div>

        <!-- Navigation Keys -->
        <div class="d-flex flex-column align-items-center mb-4">
            <button class="btn btn-frosted border-white border-opacity-10 text-white mb-2" 
                data-action="send-key" data-id="<%= screen.id %>" data-key="KEY_UP" data-label="Arriba" style="width: 50px; height: 50px;">
                <i class="bi bi-chevron-up"></i>
            </button>
            <div class="d-flex gap-2 mb-2">
                <button class="btn btn-frosted border-white border-opacity-10 text-white" 
                    data-action="send-key" data-id="<%= screen.id %>" data-key="KEY_LEFT" data-label="Izquierda" style="width: 50px; height: 50px;">
                    <i class="bi bi-chevron-left"></i>
                </button>
                <button class="btn btn-primary shadow-lg border-0 fw-bold" 
                    data-action="send-key" data-id="<%= screen.id %>" data-key="KEY_ENTER" data-label="Enter" 
                    style="width: 50px; height: 50px; background: var(--gradient-neon);">
                    OK
                </button>
                <button class="btn btn-frosted border-white border-opacity-10 text-white" 
                    data-action="send-key" data-id="<%= screen.id %>" data-key="KEY_RIGHT" data-label="Derecha" style="width: 50px; height: 50px;">
                    <i class="bi bi-chevron-right"></i>
                </button>
            </div>
            <button class="btn btn-frosted border-white border-opacity-10 text-white" 
                data-action="send-key" data-id="<%= screen.id %>" data-key="KEY_DOWN" data-label="Abajo" style="width: 50px; height: 50px;">
                <i class="bi bi-chevron-down"></i>
            </button>
        </div>

        <!-- Function Keys -->
        <div class="row g-2">
            <div class="col-4">
                <button class="btn btn-frosted border-info border-opacity-25 text-info w-100 py-2" 
                    data-action="send-key" data-id="<%= screen.id %>" data-key="KEY_HOME" data-label="Home">
                    <i class="bi bi-house"></i>
                </button>
            </div>
            <div class="col-4">
                <button class="btn btn-frosted border-info border-opacity-25 text-info w-100 py-2" 
                    data-action="send-key" data-id="<%= screen.id %>" data-key="KEY_RETURN" data-label="Return">
                    <i class="bi bi-arrow-return-left"></i>
                </button>
            </div>
            <div class="col-4">
                <button class="btn btn-frosted border-info border-opacity-25 text-info w-100 py-2" 
                    data-action="send-key" data-id="<%= screen.id %>" data-key="KEY_MENU" data-label="Menu">
                    <i class="bi bi-list"></i>
                </button>
            </div>
        </div>
    </div>

    <!-- Browser Action -->
    <button class="btn btn-frosted border-info border-opacity-25 text-info w-100 mt-4 py-2" 
        data-action="open-browser" data-id="<%= screen.id %>"
        <%=!screen.client_token ? 'disabled' : '' %>>
        <i class="bi bi-globe2 me-2"></i> Abrir Navegador en TV
    </button>
</div>