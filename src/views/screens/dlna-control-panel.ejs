<!-- DLNA Control Panel Premium -->
<div class="dlna-panel">
    <!-- Power Controls -->
    <div class="row g-2 mb-4">
        <% if (screen.mac_address) { %>
            <div class="col-6">
                <button class="btn btn-frosted border-success border-opacity-25 text-success w-100 py-2" 
                    data-action="power-on" data-id="<%= screen.id %>">
                    <i class="bi bi-lightning-charge-fill me-2"></i>Encender
                </button>
            </div>
            <div class="col-6">
                <button class="btn btn-frosted border-danger border-opacity-25 text-danger w-100 py-2" 
                    data-action="power-off" data-id="<%= screen.id %>">
                    <i class="bi bi-power me-2"></i>Apagar
                </button>
            </div>
        <% } else { %>
            <div class="col-12">
                <div class="alert glass-effect border-warning border-opacity-20 text-warning d-flex align-items-center mb-0 p-3" role="alert">
                    <i class="bi bi-exclamation-triangle-fill me-3 fs-5"></i>
                    <small>Configura la dirección MAC en los detalles de la pantalla para habilitar el Encendido Remoto (Wake-on-LAN).</small>
                </div>
            </div>
        <% } %>
    </div>

    <!-- Main Actions -->
    <div class="row g-2 mb-4">
        <div class="col-6">
            <a href="/screens/player-viewer/<%= screen.id %>" target="_blank" 
                class="btn btn-frosted border-info border-opacity-25 text-info w-100 py-3 text-decoration-none d-flex flex-column align-items-center">
                <i class="bi bi-eye fs-4 mb-1"></i>
                <small class="fw-bold">Ver Reproductor</small>
            </a>
        </div>
        <div class="col-6">
            <button class="btn btn-frosted border-primary border-opacity-25 text-primary w-100 py-3 d-flex flex-column align-items-center"
                data-action="openPlayerOnTV" data-id="<%= screen.id %>" data-ip="<%= screen.ip_address %>"
                <%=!screen.ip_address ? 'disabled' : '' %>>
                <i class="bi bi-tv fs-4 mb-1"></i>
                <small class="fw-bold">Abrir en TV</small>
            </button>
        </div>
    </div>

    <!-- Media Library -->
    <div class="glass-effect rounded-4 p-4 border border-white border-opacity-5 mb-4">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h6 class="text-white font-display mb-0">Biblioteca de Medios</h6>
            <button class="btn btn-action-premium btn-ping-premium px-3 py-1" data-action="uploadMedia" data-id="<%= screen.id %>" style="width: auto;">
                <i class="bi bi-cloud-upload me-2"></i>Subir
            </button>
        </div>

        <div id="mediaGrid-<%= screen.id %>" class="media-premium-grid">
            <% if (mediaFiles.length===0) { %>
                <div class="text-center py-5 text-white-50 opacity-50 border border-white border-opacity-5 border-dashed rounded-4">
                    <i class="bi bi-film fs-1 mb-2 d-block"></i>
                    <p class="small mb-0">No se encontraron videos disponibles</p>
                </div>
            <% } else { %>
                <% mediaFiles.forEach(file=> { %>
                    <div class="media-glass-card">
                        <div class="media-icon-container">
                            <i class="bi bi-play-circle-fill"></i>
                        </div>
                        <div class="media-body">
                            <span class="media-filename" title="<%= file %>"><%= file %></span>
                        </div>
                        <div class="media-btns">
                            <button class="btn-play-action"
                                data-action="playDLNAMedia" data-id="<%= screen.id %>" data-ip="<%= screen.ip_address %>" data-file="<%= file %>">
                                <i class="bi bi-play-fill"></i>
                            </button>
                            <button class="btn-delete-action" data-action="deleteMedia" data-file="<%= file %>">
                                <i class="bi bi-trash-fill"></i>
                            </button>
                        </div>
                    </div>
                <% }) %>
            <% } %>
        </div>
    </div>

    <!-- Custom URL & Control -->
    <div class="glass-effect rounded-4 p-3 border border-white border-opacity-5">
        <label class="form-label small text-white-50 fw-bold mb-2">Reproducir desde URL:</label>
        <div class="input-group mb-3">
            <input type="url" class="form-control glass-effect border-opacity-10 text-white" id="customUrl-<%= screen.id %>"
                placeholder="http://servidor.com/video.mp4">
            <button class="btn btn-action-premium px-3" data-action="playCustomUrl" data-id="<%= screen.id %>" style="width: auto;">
                <i class="bi bi-play-fill fs-5"></i>
            </button>
        </div>

        <button class="btn btn-frosted border-danger border-opacity-25 text-danger w-100 py-2 d-flex align-items-center justify-content-center"
            data-action="stopDLNA" data-id="<%= screen.id %>" data-ip="<%= screen.ip_address %>" <%=!screen.ip_address ? 'disabled' : '' %>>
            <i class="bi bi-stop-circle me-2"></i> Detener Reproducción Activa
        </button>
    </div>
</div>

<style>
    .media-premium-grid {
        display: flex;
        flex-direction: column;
        gap: 10px;
        max-height: 250px;
        overflow-y: auto;
        padding-right: 5px;
    }

    .media-glass-card {
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid rgba(255, 255, 255, 0.05);
        border-radius: 12px;
        display: flex;
        align-items: center;
        padding: 10px 15px;
        transition: all 0.3s ease;
    }

    .media-glass-card:hover {
        background: rgba(255, 255, 255, 0.08);
        border-color: var(--neon-blue);
        transform: translateX(5px);
    }

    .media-icon-container {
        font-size: 1.5rem;
        color: var(--success-mint);
        margin-right: 15px;
        display: flex;
        align-items: center;
    }

    .media-body {
        flex: 1;
        min-width: 0;
    }

    .media-filename {
        display: block;
        color: white;
        font-size: 0.85rem;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .media-btns {
        display: flex;
        gap: 8px;
    }

    .btn-play-action, .btn-delete-action {
        border: none;
        background: transparent;
        padding: 5px;
        transition: transform 0.2s;
        font-size: 1.1rem;
    }

    .btn-play-action { color: var(--success-mint); }
    .btn-delete-action { color: var(--punch-red); }

    .btn-play-action:hover, .btn-delete-action:hover {
        transform: scale(1.2);
    }

    /* Scrollbar minimalista */
    .media-premium-grid::-webkit-scrollbar {
        width: 4px;
    }
    .media-premium-grid::-webkit-scrollbar-track {
        background: transparent;
    }
    .media-premium-grid::-webkit-scrollbar-thumb {
        background: rgba(255, 255, 255, 0.1);
        border-radius: 10px;
    }
</style>