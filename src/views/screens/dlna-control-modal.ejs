<!-- DLNA Screen Control Modal -->
<div class="modal fade" id="dlnaControlModal<%= screen.id %>" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content glass-effect border-opacity-10">
            <div class="modal-header glass-effect border-bottom-0 p-4">
                <h5 class="modal-title font-display fw-bold text-white">
                    <i class="bi bi-cast me-2 text-success"></i>
                    Control DLNA - <%= screen.name %>
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">
                <!-- Connectivity Status -->
                <div class="alert glass-effect border-opacity-10 d-flex align-items-center mb-4 border-<%= screen.ip_address ? 'success' : 'danger' %>">
                    <i class="bi bi-<%= screen.ip_address ? 'hdd-network-fill' : 'exclamation-octagon-fill' %> me-2 fs-4 text-<%= screen.ip_address ? 'success' : 'danger' %>"></i>
                    <div>
                        <strong class="text-white">IP Configurada:</strong>
                        <span class="text-white-50"><%= screen.ip_address || 'Pendiente de configurar' %></span>
                    </div>
                </div>

                <div class="dlna-control-container">
                    <%- include('dlna-control-panel', { screen: screen, mediaFiles: (typeof mediaFiles !== 'undefined' ? mediaFiles : []) }) %>
                </div>
            </div>
            <div class="modal-footer border-top-0 p-4">
                <button type="button" class="btn btn-frosted border border-white border-opacity-10 text-white w-auto px-4" data-bs-dismiss="modal">Cerrar</button>
            </div>
        </div>
    </div>
</div>

<style>
    [id^="dlnaControlModal"] .modal-content {
        background: var(--space-deep);
        border: 1px solid var(--glass-border);
    }
</style>
