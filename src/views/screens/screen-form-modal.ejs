<!-- Screen Create/Edit Modal -->
<div class="modal fade" id="screenFormModal" tabindex="-1" aria-labelledby="screenFormModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="screenFormModalLabel">
                    <i class="bi bi-tv me-2"></i>
                    <span id="modalTitle">Nueva Pantalla</span>
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form id="screenForm">
                    <input type="hidden" id="screenId" name="id">

                    <!-- Name Field -->
                    <div class="mb-3">
                        <label for="screenName" class="form-label">
                            <i class="bi bi-tag me-1"></i>Nombre de la Pantalla
                        </label>
                        <input type="text" class="form-control" id="screenName" name="name"
                            placeholder="Ej: LG TV Sala Principal" required>
                        <div class="form-text">Nombre descriptivo para identificar la pantalla</div>
                    </div>

                    <!-- Device Type Field -->
                    <div class="mb-3">
                        <label for="deviceType" class="form-label">
                            <i class="bi bi-gear me-1"></i>Tipo de Dispositivo
                        </label>
                        <select class="form-select" id="deviceType" name="device_type" required>
                            <option value="">Seleccionar tipo...</option>
                            <option value="browser">Smart TV (Browser/WebSocket)</option>
                            <option value="dlna">DLNA/Chromecast</option>
                        </select>
                        <div class="form-text">Tipo de conexión que usa la pantalla</div>
                    </div>

                    <!-- IP Address Field -->
                    <div class="mb-3">
                        <label for="ipAddress" class="form-label">
                            <i class="bi bi-hdd-network me-1"></i>Dirección IP
                        </label>
                        <input type="text" class="form-control" id="ipAddress" name="ip_address"
                            placeholder="192.168.1.100" pattern="^(?:[0-9]{1,3}\.){3}[0-9]{1,3}$">
                        <div class="form-text">Dirección IP local de la pantalla</div>
                    </div>

                    <!-- MAC Address Field -->
                    <div class="mb-3">
                        <label for="macAddress" class="form-label">
                            <i class="bi bi-ethernet me-1"></i>Dirección MAC
                        </label>
                        <input type="text" class="form-control" id="macAddress" name="mac_address"
                            placeholder="AA:BB:CC:DD:EE:FF" pattern="^([0-9A-Fa-f]{2}[:-]){5}([0-9A-Fa-f]{2})$">
                        <div class="form-text">Necesaria para Wake-on-LAN (opcional)</div>
                    </div>

                    <!-- Branch ID (Hidden - will be set automatically) -->
                    <input type="hidden" id="branchId" name="branch_id" value="1">
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                    <i class="bi bi-x-lg me-1"></i>Cancelar
                </button>
                <button type="button" class="btn btn-primary" id="saveScreenBtn">
                    <i class="bi bi-save me-1"></i>Guardar
                </button>
            </div>
        </div>
    </div>
</div>