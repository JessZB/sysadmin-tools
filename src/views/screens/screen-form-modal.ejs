<!-- Screen Create/Edit Modal Premium -->
<div class="modal fade" id="screenFormModal" tabindex="-1" aria-labelledby="screenFormModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content glass-effect border-opacity-10 border-white">
            <div class="modal-header glass-effect border-bottom-0 p-4">
                <h5 class="modal-title font-display fw-bold text-white" id="screenFormModalLabel">
                    <i class="bi bi-display me-2 text-primary"></i>
                    <span id="modalTitle">Nueva Pantalla</span>
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4">
                <form id="screenForm">
                    <input type="hidden" id="screenId" name="id">

                    <!-- Name Field -->
                    <div class="mb-4">
                        <label for="screenName" class="form-label text-white-50 small fw-bold text-uppercase ls-1">
                            <i class="bi bi-tag me-2 text-primary"></i>Nombre de la Pantalla
                        </label>
                        <input type="text" class="form-control glass-effect border-opacity-10 text-white p-3" id="screenName" name="name"
                            placeholder="Ej: Samsung Sala VIP" required>
                    </div>

                    <!-- Device Type Field -->
                    <div class="mb-4">
                        <label for="deviceType" class="form-label text-white-50 small fw-bold text-uppercase ls-1">
                            <i class="bi bi-gear me-2 text-primary"></i>Tipo de Dispositivo
                        </label>
                        <select class="form-select glass-effect border-opacity-10 text-white p-3" id="deviceType" name="device_type" required>
                            <option value="" class="bg-dark">Seleccionar tipo...</option>
                            <option value="browser" class="bg-dark">Smart TV (LG / Samsung)</option>
                            <option value="dlna" class="bg-dark">Dispositivo DLNA / Cast</option>
                        </select>
                    </div>

                    <div class="row g-3">
                        <!-- IP Address Field -->
                        <div class="col-md-6 mb-4">
                            <label for="ipAddress" class="form-label text-white-50 small fw-bold text-uppercase ls-1">
                                <i class="bi bi-hdd-network me-2 text-primary"></i>Dirección IP
                            </label>
                            <input type="text" class="form-control glass-effect border-opacity-10 text-white p-3 font-monospace" id="ipAddress" name="ip_address"
                                placeholder="192.168.x.x" pattern="^(?:[0-9]{1,3}\.){3}[0-9]{1,3}$">
                        </div>

                        <!-- MAC Address Field -->
                        <div class="col-md-6 mb-4">
                            <label for="macAddress" class="form-label text-white-50 small fw-bold text-uppercase ls-1">
                                <i class="bi bi-ethernet me-2 text-primary"></i>Dirección MAC
                            </label>
                            <input type="text" class="form-control glass-effect border-opacity-10 text-white p-3 font-monospace" id="macAddress" name="mac_address"
                                placeholder="AA:BB:CC..." pattern="^([0-9A-Fa-f]{2}[:-]){5}([0-9A-Fa-f]{2})$">
                        </div>
                    </div>

                    <input type="hidden" id="branchId" name="branch_id" value="1">
                </form>
            </div>
            <div class="modal-footer border-top-0 p-4">
                <button type="button" class="btn btn-frosted border border-white border-opacity-10 text-white px-4" data-bs-dismiss="modal">
                    Cancelar
                </button>
                <button type="button" class="btn btn-action-premium btn-ping-premium px-5" id="saveScreenBtn" style="width: auto;">
                    <i class="bi bi-save me-2"></i>Guardar Cambios
                </button>
            </div>
        </div>
    </div>
</div>

<style>
    #screenFormModal .modal-content {
        background: var(--space-deep);
        border: 1px solid var(--glass-border);
    }
    
    #screenFormModal .form-control::placeholder {
        color: rgba(255, 255, 255, 0.5);
    }
</style>