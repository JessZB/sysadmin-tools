<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SysAdmin Suite - Menú Principal</title>
    <link rel="icon" type="image/x-icon" href="/favicon.webp">
    <link href="/css/lib/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/lib/bootstrap-icons.css">
    <link href="/css/lib/font-awesome.css" rel="stylesheet">
    <link href="/css/custom-theme.css" rel="stylesheet">
    <style>
        body {
            background-color: var(--space-dark);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow-x: hidden;
        }

        .menu-container {
            max-width: 1200px;
            width: 100%;
            padding: 40px 20px;
            position: relative;
            z-index: 1;
        }

        /* Fondo Decorativo (Mesh Gradient) */
        .mesh-bg {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: 
                radial-gradient(at 0% 0%, rgba(0, 210, 255, 0.15) 0px, transparent 50%),
                radial-gradient(at 100% 100%, rgba(110, 64, 255, 0.15) 0px, transparent 50%);
            z-index: -1;
        }

        .header-section {
            text-align: center;
            margin-bottom: 60px;
        }

        .header-section h1 {
            font-size: 4.5rem;
            background: linear-gradient(to bottom, #fff 30%, rgba(255, 255, 255, 0.5));
            -webkit-background-clip: text;
            background-clip: text;
            -webkit-text-fill-color: transparent;
            margin-bottom: 15px;
            letter-spacing: -0.04em;
        }

        .header-section p {
            font-size: 1.25rem;
            color: rgba(255, 255, 255, 0.5);
            font-family: var(--font-body);
        }

        .menu-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 24px;
        }

        .menu-card {
            background: var(--glass-bg);
            backdrop-filter: blur(12px);
            border: 1px solid var(--glass-border);
            border-radius: 32px;
            padding: 40px 30px;
            text-align: center;
            transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1);
            text-decoration: none;
            display: block;
            box-shadow: var(--glass-shadow);
        }

        .menu-card:hover {
            transform: translateY(-10px) scale(1.02);
            border-color: var(--neon-blue);
            background: rgba(255, 255, 255, 0.05);
            box-shadow: 0 20px 40px rgba(0, 210, 255, 0.1);
        }

        .menu-icon {
            font-size: 3.5rem;
            margin-bottom: 25px;
            color: var(--neon-blue);
            transition: transform 0.5s ease;
        }

        .menu-card:hover .menu-icon {
            transform: scale(1.1);
        }

        .menu-title {
            font-size: 1.4rem;
            color: #fff;
            margin-bottom: 12px;
        }

        .menu-description {
            font-size: 0.95rem;
            color: rgba(255, 255, 255, 0.5);
            line-height: 1.5;
        }

        .user-info-section {
            position: fixed;
            top: 30px;
            right: 30px;
        }

        /* Animación Staggered */
        @keyframes reveal {
            from { opacity: 0; transform: translateY(20px) scale(0.95); }
            to { opacity: 1; transform: translateY(0) scale(1); }
        }

        .menu-card {
            opacity: 0;
            animation: reveal 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
        }
    </style>
</head>

<body class="noise-overlay">
    <div class="menu-container">
        <!-- Header -->
        <div class="header-section">
            <h1><i class="fa-solid fa-server me-3"></i>SysAdmin Suite</h1>
            <p>Panel de Control y Gestión</p>
        </div>

        <!-- User Info -->
        <div class="user-info">
            <h5>Bienvenido, <%= user.username %>
            </h5>
            <span class="role-badge <%= user.role === 'admin' ? 'role-admin' : 'role-analista' %>">
                <%= user.role==='admin' ? 'Administrador' : 'Analista' %>
            </span>
            <% if (user.branch_name) { %>
                <div class="mt-2">
                    <small><i class="fa-solid fa-building me-1"></i>
                        <%= user.branch_name %>
                    </small>
                </div>
                <% } %>
        </div>

        <!-- Menu Grid -->
        <div class="menu-grid">
            <% if (user.modules && user.modules.includes('dashboard')) { %>
            <a href="/dashboard" class="menu-card">
                <div class="menu-icon"><i class="fa-solid fa-chart-line"></i></div>
                <h3 class="menu-title">Monitor Jobs</h3>
                <p class="menu-description">Monitoreo de trabajos y terminales POS</p>
            </a>
            <% } %>

            <% if (user.modules && user.modules.includes('terminals')) { %>
            <a href="/terminals" class="menu-card">
                <div class="menu-icon"><i class="fa-solid fa-desktop"></i></div>
                <h3 class="menu-title">Terminales</h3>
                <p class="menu-description">Gestión de terminales POS</p>
            </a>
            <% } %>

            <% if (user.modules && user.modules.includes('branches')) { %>
            <a href="/branches" class="menu-card">
                <div class="menu-icon"><i class="fa-solid fa-building"></i></div>
                <h3 class="menu-title">Sucursales</h3>
                <p class="menu-description">Administrar sucursales</p>
            </a>
            <% } %>

            <% if (user.modules && user.modules.includes('users')) { %>
            <a href="/users" class="menu-card">
                <div class="menu-icon"><i class="fa-solid fa-users"></i></div>
                <h3 class="menu-title">Usuarios</h3>
                <p class="menu-description">Gestión de usuarios del sistema</p>
            </a>
            <% } %>

            <% if (user.modules && user.modules.includes('barcode')) { %>
            <a href="/barcode" class="menu-card">
                <div class="menu-icon"><i class="fa-solid fa-barcode"></i></div>
                <h3 class="menu-title">Códigos de Barra</h3>
                <p class="menu-description">Generador PLU Dibal</p>
            </a>
            <% } %>

            <% if (user.modules && user.modules.includes('services')) { %>
            <a href="/services" class="menu-card">
                <div class="menu-icon"><i class="fa-solid fa-heartbeat"></i></div>
                <h3 class="menu-title">Monitoreo Servicios</h3>
                <p class="menu-description">Verificar disponibilidad mediante ping</p>
            </a>
            <% } %>

            <% if (user.modules && user.modules.includes('audit')) { %>
            <a href="/audit" class="menu-card accent">
                <div class="menu-icon"><i class="fa-solid fa-clock-rotate-left"></i></div>
                <h3 class="menu-title">Auditoría</h3>
                <p class="menu-description">Registro de actividades</p>
            </a>
            <% } %>

            <% if (user.modules && user.modules.includes('screens')) { %>
            <a href="/screens" class="menu-card">
                <div class="menu-icon"><i class="fa-solid fa-tv"></i></div>
                <h3 class="menu-title">Pantallas</h3>
                <p class="menu-description">Gestión de TV y DLNA</p>
            </a>
            <% } %>
        </div>

        <!-- Logout Button -->
        <div class="text-center">
            <a href="/logout" class="logout-btn">
                <i class="fa-solid fa-right-from-bracket me-2"></i>Cerrar Sesión
            </a>
        </div>
    </div>

    <script src="/js/lib/bootstrap.bundle.min.js"></script>
</body>

</html>