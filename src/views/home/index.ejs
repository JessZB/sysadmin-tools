<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SysAdmin Suite - Menú Principal</title>
    <link rel="icon" type="image/x-icon" href="/favicon.webp">
    <link href="/css/lib/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/lib/bootstrap-icons.css">
    <link href="/css/lib/font-awesome.css" rel="stylesheet">
    <link href="/css/custom-theme.css" rel="stylesheet">
    <style>
        body {
            background-color: var(--space-indigo);
            min-height: 100vh;
            overflow-x: hidden;
        }

        /* ---- Main Container ---- */
        .home-layout {
            max-width: 1100px;
            margin: 0 auto;
            padding: 40px 24px 60px;
        }

        /* ---- Header ---- */
        .home-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 40px;
            padding-bottom: 20px;
            border-bottom: 1px dashed var(--glass-border);
            flex-wrap: wrap;
            gap: 16px;
        }

        .home-brand {
            font-family: var(--font-tech);
            font-size: 1.4rem;
            color: var(--platinum);
            display: flex;
            align-items: center;
            gap: 10px;
            letter-spacing: -1px;
        }

        .home-brand i { color: var(--flag-red); }

        .user-pill {
            display: flex;
            align-items: center;
            gap: 10px;
            background: var(--glass-bg);
            border: 1px solid var(--glass-border);
            border-radius: 4px;
            padding: 8px 16px;
        }

        .user-pill .role-badge {
            font-family: var(--font-tech);
            font-size: 0.6rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: var(--lavender-grey);
            border: 1px solid var(--glass-border);
            padding: 2px 8px;
            border-radius: 2px;
        }

        .user-pill .role-badge.role-admin  { color: var(--punch-red); border-color: rgba(239,35,60,0.3); }

        .user-pill .username {
            font-family: var(--font-body);
            font-size: 0.9rem;
            color: var(--platinum);
            font-weight: 600;
        }

        /* ---- Category Section ---- */
        .category-group {
            margin-bottom: 28px;
        }

        .category-label {
            font-family: var(--font-tech);
            font-size: 0.62rem;
            text-transform: uppercase;
            letter-spacing: 3px;
            color: var(--lavender-grey);
            opacity: 0.7;
            margin-bottom: 10px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .category-label::after {
            content: "";
            flex: 1;
            height: 1px;
            background: var(--glass-border);
        }

        /* ---- Menu Grid — Compact ---- */
        .menu-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
            gap: 8px;
        }

        /* ---- Menu Card — Horizontal Compact ---- */
        .menu-card {
            background: var(--glass-bg);
            backdrop-filter: blur(12px);
            border: 1px solid var(--glass-border);
            border-radius: 4px;
            padding: 12px 14px;
            text-decoration: none;
            display: flex;
            align-items: center;
            gap: 12px;
            transition: all 0.2s ease;
            position: relative;
            overflow: hidden;
            opacity: 0;
            animation: reveal 0.5s cubic-bezier(0.16, 1, 0.3, 1) forwards;
        }

        .menu-card::before {
            content: "";
            position: absolute;
            left: 0;
            top: 0;
            bottom: 0;
            width: 0;
            background: var(--flag-red);
            transition: width 0.25s ease;
        }

        .menu-card:hover {
            background: rgba(141, 153, 174, 0.08);
            border-color: rgba(141, 153, 174, 0.4);
            transform: translateX(2px);
        }

        .menu-card:hover::before { width: 3px; }

        .menu-icon {
            font-size: 1.2rem;
            color: var(--lavender-grey);
            transition: color 0.2s ease;
            flex-shrink: 0;
            width: 24px;
            text-align: center;
        }

        .menu-card:hover .menu-icon { color: var(--platinum); }

        .menu-text { overflow: hidden; }

        .menu-title {
            font-family: var(--font-tech);
            font-size: 0.72rem;
            color: var(--platinum);
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin: 0;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .menu-description {
            font-family: var(--font-body);
            font-size: 0.62rem;
            color: var(--lavender-grey);
            margin: 0;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        /* ---- Logout ---- */
        .logout-btn {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 10px 20px;
            background: transparent;
            border: 1px solid rgba(217, 4, 41, 0.4);
            border-radius: 4px;
            color: var(--punch-red);
            font-family: var(--font-tech);
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            text-decoration: none;
            transition: all 0.2s ease;
        }

        .logout-btn:hover {
            background: var(--flag-red);
            border-color: var(--flag-red);
            color: var(--platinum);
        }

        @keyframes reveal {
            from { opacity: 0; transform: translateY(8px); }
            to   { opacity: 1; transform: translateY(0); }
        }

        @media (max-width: 576px) {
            .menu-grid { grid-template-columns: 1fr 1fr; }
            .home-header { flex-direction: column; align-items: flex-start; }
        }
    </style>
</head>

<body class="noise-overlay">
    <div class="home-layout">

        <!-- ===== HEADER ===== -->
        <div class="home-header">
            <div class="home-brand">
                <i class="fa-solid fa-bolt-lightning"></i>
                SYS<span style="color: var(--lavender-grey); font-weight: 300;">ADMIN</span>
                <span style="font-size: 0.55rem; color: var(--lavender-grey); letter-spacing: 3px; opacity: 0.6;">SUITE</span>
            </div>

            <div class="user-pill">
                <i class="fa-solid fa-circle" style="font-size: 0.45rem; color: #4caf50;"></i>
                <span class="username"><%= user.username %></span>
                <span class="role-badge <%= user.role === 'admin' ? 'role-admin' : '' %>">
                    <%= user.role === 'admin' ? 'Admin' : 'Analista' %>
                </span>
                <% if (user.branch_name) { %>
                    <span style="font-size: 0.75rem; color: var(--lavender-grey);"><i class="fa-solid fa-building"></i> <%= user.branch_name %></span>
                <% } %>
            </div>
        </div>

        <!-- ===== MENU: Dynamic Categories ===== -->
        <% menuCategories.forEach(function(cat, catIdx) { %>
            <%
               const hasAccess = cat.modules.some(mod =>
                   mod.is_configured && (user.role === 'admin' || (user.modules && user.modules.includes(mod.code)))
               );
               if (!hasAccess) return;
            %>
            <div class="category-group">
                <div class="category-label">
                    <i class="bi <%= cat.icon %>"></i>
                    <%= cat.name %>
                </div>
                <div class="menu-grid">
                    <% cat.modules.forEach(function(mod, modIdx) { %>
                        <% if (!mod.is_configured || !(user.role === 'admin' || (user.modules && user.modules.includes(mod.code)))) return; %>
                        <a href="/<%= mod.code %>" class="menu-card" style="animation-delay: <%= (catIdx * 3 + modIdx) * 40 %>ms;">
                            <div class="menu-icon"><i class="bi <%= mod.icon || 'bi-box' %>"></i></div>
                            <div class="menu-text">
                                <p class="menu-title"><%= mod.name %></p>
                                <p class="menu-description">/<%= mod.code %></p>
                            </div>
                        </a>
                    <% }); %>
                </div>
            </div>
        <% }); %>

        <!-- ===== LOGOUT ===== -->
        <div class="mt-4">
            <a href="/logout" class="logout-btn">
                <i class="fa-solid fa-right-from-bracket"></i>Cerrar Sesión
            </a>
        </div>

    </div>

    <script src="/js/lib/bootstrap.bundle.min.js"></script>
</body>

</html>