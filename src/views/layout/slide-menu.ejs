<!-- SLIDE MENU OVERLAY -->
<div id="slideMenuOverlay" class="slide-menu-overlay">
    <div id="slideMenu" class="slide-menu">
        <!-- Header del Menú -->
        <div class="slide-menu-header">
            <div class="d-flex justify-content-between align-items-center">
                <h3 class="mb-0 text-white">
                    <i class="fa-solid fa-server me-2" aria-hidden="true"></i>SysAdmin Suite
                </h3>
                <button class="btn btn-punch btn-sm" data-slide-menu-close aria-label="Cerrar menú">
                    <i class="fa-solid fa-xmark me-1" aria-hidden="true"></i> Cerrar
                </button>
            </div>
        </div>

        <!-- Contenido del Menú -->
        <div class="slide-menu-content">
            <!-- User Info -->
            <div class="user-info-slide">
                <div class="d-flex align-items-center">
                    <div class="user-avatar">
                        <i class="fa-solid fa-user" aria-hidden="true"></i>
                    </div>
                    <div class="ms-3">
                        <h5 class="mb-0 text-white">
                            <%= user.username %>
                        </h5>
                        <span class="role-badge <%= user.role === 'admin' ? 'role-admin' : 'role-analista' %>">
                            <%= user.role==='admin' ? 'Administrador' : 'Analista' %>
                        </span>
                        <% if (user.branch_name) { %>
                            <div class="mt-1">
                                <small class="text-white-50">
                                    <i class="fa-solid fa-building me-1" aria-hidden="true"></i>
                                    <%= user.branch_name %>
                                </small>
                            </div>
                            <% } %>
                    </div>
                </div>
            </div>

            <!-- Menu Grid -->
            <!-- Menu Grid Dynamic -->
            <div class="menu-container-slide">
                <% menuCategories.forEach(function(cat) { %>
                    <% 
                       const hasAccessToCategory = cat.modules.some(mod => 
                           mod.is_configured && (user.role === 'admin' || (user.modules && user.modules.includes(mod.code)))
                       );
                       if (hasAccessToCategory) { 
                    %>
                    <div class="category-group-slide mb-4">
                        <h6 class="text-white-50 font-tech text-uppercase border-bottom border-white border-opacity-10 pb-2 mb-3" style="letter-spacing: 1px; font-size: 0.85rem;">
                            <i class="bi <%= cat.icon %> me-2"></i><%= cat.name %>
                        </h6>
                        <div class="menu-grid-slide">
                            <% cat.modules.forEach(function(mod) { %>
                                <% if (mod.is_configured && (user.role === 'admin' || (user.modules && user.modules.includes(mod.code)))) { %>
                                <a href="/<%= mod.code %>" class="menu-card">
                                    <div class="menu-icon"><i class="bi <%= mod.icon || 'bi-box' %>"></i></div>
                                    <div class="menu-content-text">
                                        <h4 class="menu-title"><%= mod.name %></h4>
                                        <p class="menu-description text-uppercase ls-1" style="font-size: 0.65rem;"><%= mod.code %></p>
                                    </div>
                                </a>
                                <% } %>
                            <% }); %>
                        </div>
                    </div>
                    <% } %>
                <% }); %>
            </div>

            <!-- Logout Button -->
            <div class="text-center mt-4">
                <a href="/logout" class="btn btn-punch btn-lg">
                    <i class="fa-solid fa-right-from-bracket me-2" aria-hidden="true"></i>Cerrar Sesión
                </a>
            </div>
        </div>
    </div>
</div>
<style>
    /* ============================================
    SLIDE MENU NOTHING STYLE (ORTHOGONAL & GLASS)
    ============================================ */

    .slide-menu-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: radial-gradient(circle at center, rgba(43, 45, 66, 0.92), rgba(43, 45, 66, 0.99));
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        z-index: 9999;
        opacity: 0;
        visibility: hidden;
        transition: opacity 0.4s ease, visibility 0.4s ease;
        overflow-y: auto;
        -webkit-overflow-scrolling: touch;
    }

    .slide-menu-overlay.active {
        opacity: 1;
        visibility: visible;
    }

    .slide-menu {
        position: relative;
        width: calc(100% - 40px);
        max-width: 1100px;
        margin: 30px auto;
        transform: translateY(-16px);
        opacity: 0;
        transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.4s ease;
        padding: 0;
    }

    .slide-menu.active {
        transform: translateY(0);
        opacity: 1;
    }

    /* --- Header Bar --- */
    .slide-menu-header {
        background: var(--flag-red);
        padding: 16px 24px;
        border-radius: 4px;
        margin-bottom: 16px;
        border-bottom: 3px solid var(--punch-red);
    }

    .slide-menu-header h3 {
        font-family: var(--font-tech);
        text-transform: uppercase;
        letter-spacing: 1px;
        font-size: 1rem;
    }

    /* --- User Info Bar (compact) --- */
    .user-info-slide {
        background: var(--glass-bg);
        border: 1px solid var(--glass-border);
        border-radius: 4px;
        padding: 12px 18px;
        margin-bottom: 16px;
        display: flex;
        align-items: center;
        gap: 14px;
        backdrop-filter: blur(12px);
    }

    .user-avatar {
        width: 36px;
        height: 36px;
        border-radius: 2px;
        background: var(--lavender-grey);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1rem;
        color: var(--space-indigo);
        flex-shrink: 0;
    }

    .role-badge {
        background: rgba(141, 153, 174, 0.1);
        color: var(--lavender-grey);
        border: 1px solid var(--glass-border);
        padding: 2px 8px;
        border-radius: 2px;
        font-family: var(--font-tech);
        text-transform: uppercase;
        font-size: 0.65rem;
        letter-spacing: 0.05em;
    }

    .role-admin { color: var(--punch-red) !important; border-color: rgba(239,35,60,0.35) !important; }

    /* --- Category Label --- */
    .category-group-slide {
        margin-bottom: 16px;
    }

    .category-group-slide > h6 {
        font-family: var(--font-tech);
        font-size: 0.6rem;
        text-transform: uppercase;
        letter-spacing: 3px;
        color: var(--lavender-grey);
        opacity: 0.65;
        padding-bottom: 8px;
        margin-bottom: 8px;
        border-bottom: 1px dashed var(--glass-border);
    }

    /* --- Module Grid (compact) --- */
    .menu-grid-slide {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
        gap: 6px;
        width: 100%;
    }

    /* --- Module Card (horizontal compact row) --- */
    .menu-card {
        background: var(--glass-bg);
        border: 1px solid var(--glass-border);
        border-radius: 4px;
        padding: 10px 14px;
        text-decoration: none;
        transition: all 0.2s ease;
        display: flex;
        flex-direction: row;
        align-items: center;
        gap: 10px;
        position: relative;
        overflow: hidden;
        backdrop-filter: blur(12px);
    }

    .menu-card::before {
        content: "";
        position: absolute;
        left: 0;
        top: 0;
        bottom: 0;
        width: 0;
        background: var(--flag-red);
        transition: width 0.2s ease;
    }

    .menu-card:hover {
        background: rgba(141, 153, 174, 0.08);
        border-color: rgba(141, 153, 174, 0.35);
        transform: translateX(2px);
    }

    .menu-card:hover::before { width: 3px; }

    .menu-icon {
        font-size: 1.1rem;
        color: var(--lavender-grey);
        transition: color 0.2s ease;
        flex-shrink: 0;
        width: 20px;
        text-align: center;
    }

    .menu-card:hover .menu-icon { color: var(--platinum); }

    .menu-content-text { overflow: hidden; }

    .menu-title {
        font-family: var(--font-tech);
        color: var(--platinum);
        font-size: 0.7rem;
        margin: 0;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .menu-description {
        color: var(--lavender-grey);
        font-size: 0.6rem;
        font-family: var(--font-body);
        margin: 0;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        opacity: 0.7;
    }

    /* Logout button in menu */
    .slide-menu-content > div.text-center a {
        font-family: var(--font-tech);
        font-size: 0.75rem;
        letter-spacing: 1px;
        text-transform: uppercase;
    }

    @media (max-width: 768px) {
        .slide-menu { margin: 16px auto; width: calc(100% - 24px); }
        .menu-grid-slide { grid-template-columns: 1fr 1fr; }
        .slide-menu-header { padding: 14px 18px; }
        .user-info-slide  { padding: 10px 14px; }
    }

    @media (max-width: 480px) {
        .menu-grid-slide { grid-template-columns: 1fr; }
    }
</style>