<!-- SLIDE MENU OVERLAY -->
<div id="slideMenuOverlay" class="slide-menu-overlay">
    <div id="slideMenu" class="slide-menu">
        <!-- Header del Menú -->
        <div class="slide-menu-header">
            <div class="d-flex justify-content-between align-items-center">
                <h3 class="mb-0 text-white">
                    <i class="fa-solid fa-server me-2" aria-hidden="true"></i>SysAdmin Suite
                </h3>
                <button class="btn btn-punch btn-sm" data-slide-menu-close aria-label="Cerrar menú">
                    <i class="fa-solid fa-xmark me-1" aria-hidden="true"></i> Cerrar
                </button>
            </div>
        </div>

        <!-- Contenido del Menú -->
        <div class="slide-menu-content">
            <!-- User Info -->
            <div class="user-info-slide">
                <div class="d-flex align-items-center">
                    <div class="user-avatar">
                        <i class="fa-solid fa-user" aria-hidden="true"></i>
                    </div>
                    <div class="ms-3">
                        <h5 class="mb-0 text-white">
                            <%= user.username %>
                        </h5>
                        <span class="role-badge <%= user.role === 'admin' ? 'role-admin' : 'role-analista' %>">
                            <%= user.role==='admin' ? 'Administrador' : 'Analista' %>
                        </span>
                        <% if (user.branch_name) { %>
                            <div class="mt-1">
                                <small class="text-white-50">
                                    <i class="fa-solid fa-building me-1" aria-hidden="true"></i>
                                    <%= user.branch_name %>
                                </small>
                            </div>
                            <% } %>
                    </div>
                </div>
            </div>

            <!-- Menu Grid -->
            <div class="menu-grid-slide">
                <% if (user.modules && user.modules.includes('dashboard')) { %>
                <a href="/dashboard" class="menu-card">
                    <div class="menu-icon"><i class="fa-solid fa-chart-line" aria-hidden="true"></i></div>
                    <div class="menu-content-text">
                        <h4 class="menu-title">Monitor Jobs</h4>
                        <p class="menu-description">Monitoreo de trabajos y terminales</p>
                    </div>
                </a>
                <% } %>

                <% if (user.modules && user.modules.includes('terminals')) { %>
                <a href="/terminals" class="menu-card">
                    <div class="menu-icon"><i class="fa-solid fa-desktop"></i></div>
                    <div class="menu-content-text">
                        <h4 class="menu-title">Terminales</h4>
                        <p class="menu-description">Gestión de terminales POS</p>
                    </div>
                </a>
                <% } %>

                <% if (user.modules && user.modules.includes('branches')) { %>
                <a href="/branches" class="menu-card">
                    <div class="menu-icon"><i class="fa-solid fa-building"></i></div>
                    <div class="menu-content-text">
                        <h4 class="menu-title">Sucursales</h4>
                        <p class="menu-description">Administrar sucursales</p>
                    </div>
                </a>
                <% } %>

                <% if (user.modules && user.modules.includes('users')) { %>
                <a href="/users" class="menu-card">
                    <div class="menu-icon"><i class="fa-solid fa-users"></i></div>
                    <div class="menu-content-text">
                        <h4 class="menu-title">Usuarios</h4>
                        <p class="menu-description">Gestión de usuarios</p>
                    </div>
                </a>
                <% } %>

                <% if (user.modules && user.modules.includes('barcode')) { %>
                <a href="/barcode" class="menu-card">
                    <div class="menu-icon"><i class="fa-solid fa-barcode"></i></div>
                    <div class="menu-content-text">
                        <h4 class="menu-title">Códigos de Barra</h4>
                        <p class="menu-description">Generador PLU Dibal</p>
                    </div>
                </a>
                <% } %>

                <% if (user.modules && user.modules.includes('services')) { %>
                <a href="/services" class="menu-card">
                    <div class="menu-icon"><i class="fa-solid fa-heartbeat"></i></div>
                    <div class="menu-content-text">
                        <h4 class="menu-title">Monitoreo Servicios</h4>
                        <p class="menu-description">Verificar disponibilidad</p>
                    </div>
                </a>
                <% } %>

                <% if (user.modules && user.modules.includes('audit')) { %>
                <a href="/audit" class="menu-card accent">
                    <div class="menu-icon"><i class="fa-solid fa-clock-rotate-left"></i></div>
                    <div class="menu-content-text">
                        <h4 class="menu-title">Auditoría</h4>
                        <p class="menu-description">Registro de actividades</p>
                    </div>
                </a>
                <% } %>

                <% if (user.modules && user.modules.includes('screens')) { %>
                <a href="/screens" class="menu-card">
                    <div class="menu-icon"><i class="fa-solid fa-tv"></i></div>
                    <div class="menu-content-text">
                        <h4 class="menu-title">Pantallas</h4>
                        <p class="menu-description">Gestión de TV y DLNA</p>
                    </div>
                </a>
                <% } %>
            </div>

            <!-- Logout Button -->
            <div class="text-center mt-4">
                <a href="/logout" class="btn btn-punch btn-lg">
                    <i class="fa-solid fa-right-from-bracket me-2" aria-hidden="true"></i>Cerrar Sesión
                </a>
            </div>
        </div>
    </div>
</div>
<style>
        /* ============================================
        SLIDE MENU PREMIUM (GLASSMORPHISM)
        ============================================ */

        .slide-menu-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: radial-gradient(circle at center, rgba(11, 14, 20, 0.8), rgba(11, 14, 20, 0.98));
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        z-index: 9999;
        opacity: 0;
        visibility: hidden;
        transition: opacity 0.5s ease, visibility 0.5s ease;
        overflow-y: auto;
        -webkit-overflow-scrolling: touch;
        }

        .slide-menu-overlay.active {
        opacity: 1;
        visibility: visible;
        }

        .slide-menu {
        position: relative;
        width: 100%;
        max-width: 1200px;
        margin: 40px auto;
        transform: translateY(-50px);
        opacity: 0;
        transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.6s ease;
        padding: 20px;
        }

        .slide-menu.active {
        transform: translateY(0);
        opacity: 1;
        }

        .slide-menu-header {
        background: var(--gradient-neon);
        padding: 30px;
        border-radius: 24px;
        margin-bottom: 40px;
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.4);
        position: relative;
        overflow: hidden;
        }

        .slide-menu-header::after {
        content: "";
        position: absolute;
        top: -50%;
        left: -50%;
        width: 200%;
        height: 200%;
        background: linear-gradient(45deg, transparent, rgba(255, 255, 255, 0.1), transparent);
        transform: rotate(45deg);
        animation: shine 4s infinite linear;
        }

        @keyframes shine {
        0% { transform: translateX(-100%) rotate(45deg); }
        100% { transform: translateX(100%) rotate(45deg); }
        }

        .user-info-slide {
        background: var(--glass-bg);
        border: 1px solid var(--glass-border);
        border-radius: 24px;
        padding: 30px;
        margin-bottom: 40px;
        display: flex;
        align-items: center;
        box-shadow: var(--glass-shadow);
        }

        .user-avatar {
        width: 70px;
        height: 70px;
        border-radius: 20px;
        background: var(--gradient-neon);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.8rem;
        color: white;
        box-shadow: var(--shadow-neon);
        transform: rotate(-5deg);
        }

        .role-badge {
        background: rgba(255, 255, 255, 0.1);
        color: var(--neon-blue);
        border: 1px solid rgba(0, 210, 255, 0.3);
        padding: 4px 12px;
        border-radius: 12px;
        font-family: var(--font-display);
        text-transform: uppercase;
        letter-spacing: 0.05em;
        }

        .menu-grid-slide {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 20px;
        }

        .menu-card {
        background: var(--glass-bg);
        border: 1px solid var(--glass-border);
        border-radius: 24px;
        padding: 30px;
        text-decoration: none;
        transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
        position: relative;
        overflow: hidden;
        }

        .menu-card:hover {
        background: rgba(255, 255, 255, 0.05);
        border-color: var(--neon-blue);
        transform: translateY(-5px);
        box-shadow: 0 15px 30px rgba(0, 210, 255, 0.15);
        }

        .menu-icon {
        font-size: 2.5rem;
        margin-bottom: 15px;
        color: var(--neon-blue);
        transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
        }

        .menu-card:hover .menu-icon {
        transform: scale(1.1) rotate(5deg);
        color: #fff;
        }

        .menu-title {
        font-family: var(--font-display);
        color: white;
        font-size: 1.25rem;
        margin-bottom: 8px;
        }

        .menu-description {
        color: rgba(255, 255, 255, 0.5);
        font-size: 0.9rem;
        }

        @media (max-width: 768px) {
        .menu-card {
        flex-direction: row;
        text-align: left;
        padding: 20px;
        }
        .menu-icon {
        margin-bottom: 0;
        margin-right: 20px;
        font-size: 2rem;
        }
        .slide-menu {
        margin: 10px;
        padding-bottom: 80px;
        }
        }
        </style>